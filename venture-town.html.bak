// ══════════════════════════════════════
// 台詞管理器 DialogueManager
// ══════════════════════════════════════
const DM = {
  _timer: null,

  show(text, duration=4000){
    if(!text) return;
    // 教學期間，只允許 TUT 自己呼叫的台詞（duration===99999 或 TUT._allowDM）
    if(TUT && TUT.active && !TUT._allowDM) return;
    const el = document.getElementById('char-bubble');
    if(!el) return;
    if(this._timer) clearTimeout(this._timer);
    el.textContent = text;
    el.classList.add('show');
    this._timer = setTimeout(()=>{
      el.classList.remove('show');
      this._timer = null;
    }, duration);
  },

  // 主要觸發入口：傳入觸發鍵值
  trigger(key){
    const text = DIALOGUES[key];
    if(text) this.show(text);
  },

  // 事件觸發（by title keyword）
  onEvent(title){
    const map = {
      '設施補給':'event_設施補給', '原料出口熱':'event_原料出口熱',
      '商品熱銷':'event_商品熱銷', '平靜的一天':'event_平靜的一天',
      '行業熱潮':'event_行業熱潮', '區域效應':'event_區域效應',
      '地塊共鳴':'event_地塊共鳴', '颱風來襲':'event_颱風來襲',
      '地區叛亂':'event_地區叛亂',
    };
    for(const [k,v] of Object.entries(map)){
      if(title.includes(k)){
        const text = DIALOGUES[v];
        if(text) this.show(text, 5000);
        return;
      }
    }
  },

  // 設施 hover（立即覆蓋）
  onBldgHover(bldgId){
    const b = BLDG[bldgId];
    if(!b) return;
    // 四個方向的物流中心共用同一台詞
    const name = b.special==='redirect' ? '物流中心' : b.name;
    const text = DIALOGUES['bldg_hover_' + name];
    if(text) this.show(text, 4000);
  },

  // 行動 hover（立即覆蓋）
  onActionHover(label){
    // Strip emoji/symbols prefix (e.g. "🏗 購買設施" → "購買設施")
    const clean = label.replace(/^[^一-龥a-zA-Z]+/, '').trim();
    const key = 'action_hover_' + clean;
    if(DIALOGUES[key]) this.show(DIALOGUES[key], 4000);
  },

  // 行動選擇開啟（短時間，讓位給 hover）
  onActionOpen(){
    const key = 'action_open';
    if(DIALOGUES[key]) this.show(DIALOGUES[key], 4000);
  },

  // 合夥人 hover（選擇時）
  onPartnerHover(name){
    // 起始合夥人（譚雅、蕾雅、拆遷隊）用 starter_hover_，其餘用 partner_hover_
    const text = DIALOGUES['partner_hover_' + name] || DIALOGUES['starter_hover_' + name];
    if(text) this.show(text, 4000);
  },

  // 起始合夥人 hover
  onStarterHover(name){
    const key = 'starter_hover_' + name;
    if(DIALOGUES[key]) this.show(DIALOGUES[key], 4000);
  },
};

// 向後相容舊呼叫
function tryDialogue(key){ DM.trigger(key); }
function showBubble(text, dur){ DM.show(text, dur); }


// 合夥人頭像
const PARTNER_AVATARS = {
  'leya':  'data:image/png;base64,',
  'tanya': 'data:image/png;base64,',
};


// ── 譚雅：每回合開始顯示交換選單 ──
function tanyaOfferSwap(){
  if(!hasPartner('tanya')) return;
  const handOptions = G.hand.filter(h=>h.count>0);
  if(handOptions.length === 0){ addLog('👩‍💼 譚雅：手牌無設施可交換，跳過','w'); return; }
  // 隨機抽3個設施
  const pool = Object.keys(BLDG)
    .filter(id=>id!=='envy_factory')
    .sort(()=>Math.random()-.5)
    .slice(0,3);
  G._tanyaSwapPool = pool;
  G._tanyaSwapPending = true;

  // Build chooser: first pick from hand what to give
  showTanyaHandPick(pool);
}

function showTanyaHandPick(pool){
  const el = document.getElementById('card-chooser');
  document.getElementById('card-chooser-title').textContent = '👩‍💼 譚雅：選擇要交換出去的手牌設施';
  const handOptions = G.hand.filter(h=>h.count>0);
  document.getElementById('card-chooser-cards').innerHTML = handOptions.map(h=>
    makeSelCard(BLDG[h.id].emoji, BLDG[h.id].name, BLDG[h.id].desc, '', '',
      `tanyaSelectGive('${h.id}')`, '', '', '')
  ).join('');
  // Skip button
  const skipBtn = document.getElementById('card-chooser-skip');
  if(skipBtn){ skipBtn.style.display=''; skipBtn.textContent='✕ 跳過交換'; skipBtn.onclick=()=>{ closeCardChooser(); tanyaSwapDone(); }; }
  el.style.display='flex';
}

function tanyaSelectGive(giveId){
  closeCardChooser();
  const pool = G._tanyaSwapPool || [];
  // Now show 3 options to receive
  const el = document.getElementById('card-chooser');
  document.getElementById('card-chooser-title').textContent =
    `👩‍💼 譚雅：交出 ${BLDG[giveId].emoji}${BLDG[giveId].name}，選擇換入的設施（+1）`;
  document.getElementById('card-chooser-cards').innerHTML = pool.map(bid=>
    makeSelCard(BLDG[bid].emoji, BLDG[bid].name, BLDG[bid].desc+' 【+1】', '', '',
      `tanyaDoSwap('${giveId}','${bid}')`, '', '', '')
  ).join('');
  const skipBtn = document.getElementById('card-chooser-skip');
  if(skipBtn){ skipBtn.style.display=''; skipBtn.textContent='✕ 取消'; skipBtn.onclick=()=>{ closeCardChooser(); showTanyaHandPick(pool); }; }
  el.style.display='flex';
}

function tanyaDoSwap(giveId, receiveId){
  closeCardChooser();
  // Remove one from hand
  const slot = G.hand.find(h=>h.id===giveId);
  if(slot && slot.count>0) slot.count--;
  // Add received
  const existing = G.hand.find(h=>h.id===receiveId);
  if(existing) existing.count++;
  else G.hand.push({id:receiveId, count:1});
  // Mark +1 bonus for when placed
  if(!G._tanyaNewBldg) G._tanyaNewBldg={};
  G._tanyaNewBldg[receiveId] = (G._tanyaNewBldg[receiveId]||0)+1;
  addLog(`👩‍💼 譚雅：交出 ${BLDG[giveId].emoji}${BLDG[giveId].name}，換入 ${BLDG[receiveId].emoji}${BLDG[receiveId].name}（+1）！`,'g');
  renderFanHand();
  tanyaSwapDone();
}

function tanyaSwapDone(){
  G._tanyaSwapPending = false;
  G._tanyaSwapPool = null;
  openActionOverlay();
}

// ══════════════════════════════════════════════════════
// 教學系統 Tutorial System
// ══════════════════════════════════════════════════════

const TUT = {
  active: false,
  step: 0,
  waitingFor: null, // 'place_mat_factory' | 'send_el' | 'end_turn' | etc.

  // ── 教學用遊戲狀態 ──
  initState(){
    G = newGame();
    G.hand = []; // 清空手牌，教學控制
    G.card = null; // 清空元素卡，教學控制
    G.tutorialMode = true;
    G.profit = 0;
    G.phase = 'place';
    G.turn = 1; G.round = 1; G.maxTurns = 10;
    G.goal = 30;
  },

  start(){
    TUT.active = true;
    TUT.step = 0;
    TUT.initState();
    // 隱藏所有 UI，只留標題和格子
    TUT.setUIVisibility(false);
    render();
    setTimeout(()=>TUT.next(), 200);
  },

  // 逐步顯示 UI
  setUIVisibility(show){
    const ids = ['hdr','profit-area','pbar','ev-banner','hand-fan-area',
                 'partner-section','btn-next','talent-section-title','talent-panel',
                 'el-profit','side-log','upgrade-hint'];
    ids.forEach(id=>{
      const el = document.getElementById(id);
      if(el) el.style.visibility = show ? '' : 'hidden';
    });
    // left panel and right panel
    const panels = document.querySelectorAll('#main .panel');
    panels.forEach(p=>{ if(p) p.style.visibility = show ? '' : 'hidden'; });
  },

  next(){
    TUT.step++;
    const fn = TUT[`step${TUT.step}`];
    if(fn) fn.call(TUT);
  },

  // ── Step 1: 只顯示標題 + 格子 ──
  step1(){
    TUT.setUIVisibility(false);
    // 確保 hdr logo 可見（只顯示標題）
    const logo = document.getElementById('logo');
    const hdr = document.getElementById('hdr');
    if(hdr) hdr.style.visibility = '';
    if(logo) logo.style.visibility = '';
    // 隱藏收益
    const pa = document.getElementById('profit-area');
    if(pa) pa.style.visibility = 'hidden';
    TUT.bubble('（載入中...）');
    setTimeout(()=>TUT.next(), 800);
  },

  // ── Step 2: 譚雅蕾雅出現，自我介紹 ──
  step2(){
    TUT.speak([
      '哈囉！我是譚雅♡ 很高興認識你～',
      '我是蕾雅。簡單說一下——',
      '中間那個格子，就是你的小鎮！你可以在上面蓋各種設施。',
      '把設施組合起來，讓資源在裡面流轉，產生收益就是你的目標！',
    ], ()=>TUT.next());
  },

  // ── Step 3: 獲得原料廠，引導放置 ──
  step3(){
    // 顯示左側面板（手牌設施）
    const panels = document.querySelectorAll('#main .panel');
    if(panels[0]) panels[0].style.visibility = '';
    // 顯示手牌 UI
    const fanArea = document.getElementById('hand-fan-area');
    if(fanArea) fanArea.style.visibility = '';

    TUT.speak([
      '我給你一張原料廠！',
    ], ()=>{
      // 台詞說完才給原料廠，同時設定 waitingFor
      G.hand = [{id:'mat_factory', count:1}];
      TUT.waitingFor = 'place_mat_factory';
      renderHand();
      renderFanHand();
      TUT.speak([
        '把它從下方的手牌拖到格子上，試著放到小鎮裡吧～',
      ], ()=>{
        // 如果 onAction 已經處理過，waitingFor 會是 null，不要重複呼叫 next
        if(TUT.waitingFor !== 'place_mat_factory') return;
        // 檢查玩家是否已經放置了
        let hasMatFactory = false;
        for(let r=0;r<GN();r++) for(let cc=0;cc<GN();cc++) if(G.grid[r][cc]==='mat_factory') hasMatFactory=true;
        if(hasMatFactory){
          TUT.waitingFor = null;
          TUT.next();
        } else {
          TUT.highlightGrid(true);
        }
      });
    });
  },

  // ── Step 4: 投入一塊錢 ──
  step4(){
    TUT.highlightGrid(false);
    G.hand = []; // 清空手牌
    renderFanHand();
    TUT.speak([
      '很棒！設施蓋好了！',
      '現在給你一塊錢，試著從任意一側把它送入小鎮吧！',
    ], ()=>{
      // 台詞說完才給金錢，同時設定 waitingFor
      G.card = {value:1, type:'money'};
      TUT.waitingFor = 'send_el';
      renderFanHand();
      TUT.speak([
        '拖曳元素卡時小鎮四周會出現箭頭，將卡片拖到箭頭方向鬆手吧。',
      ]);
    });
  },

  // ── Step 5: 收益為零，給工廠和商店 ──
  step5(){
    // 顯示右側面板（本次收益、回合記錄）
    const panels = document.querySelectorAll('#main .panel');
    if(panels[1]) panels[1].style.visibility = '';
    const sideLog = document.getElementById('side-log');
    if(sideLog) sideLog.style.visibility = '';
    // 顯示收益欄
    const profitEl = document.getElementById('el-profit');
    if(profitEl) profitEl.style.visibility = '';
    const pa = document.getElementById('profit-area');
    if(pa) pa.style.visibility = '';
    const pbar = document.getElementById('pbar');
    if(pbar) pbar.style.visibility = '';
    render();
    TUT.speak([
      '來，我再給你一個工廠和商店——',
    ], ()=>{
      // 給工廠和商店，同時設定 waitingFor
      G.hand = [{id:'factory', count:1}, {id:'shop', count:1}];
      TUT.waitingFor = 'place_factory_shop';
      renderHand();
      renderFanHand();
      TUT.speak([
        '原料→工廠→商品→商店→金錢，這樣就能賺到錢了！',
        '把工廠和商店也放到格子上吧～',
      ], ()=>{
        // 如果 onAction 已經處理過，waitingFor 會是 null，不要重複呼叫 next
        if(TUT.waitingFor !== 'place_factory_shop') return;
        // 檢查玩家是否已經放置了
        let hasFac=false, hasShop=false;
        for(let r=0;r<GN();r++) for(let cc=0;cc<GN();cc++){
          if(G.grid[r][cc]==='factory') hasFac=true;
          if(G.grid[r][cc]==='shop') hasShop=true;
        }
        if(hasFac && hasShop){
          TUT.waitingFor = null;
          TUT.next();
        }
      });
    });
  },

  // ── Step 6: 放置完成，投入金錢並結束回合 ──
  step6(){
    // 顯示結束回合按鈕
    const btn = document.getElementById('btn-next');
    if(btn) btn.style.visibility = '';
    TUT.speak([
      '設施都蓋好了，快試試看能賺多少錢！',
      '投入你的金錢，看看能賺多少收益！',
    ], ()=>{
      // 給玩家一塊錢
      G.card = {value:1, type:'money'};
      G.phase = 'place';
      renderFanHand();
      TUT.waitingFor = 'tut_send_for_profit';
    });
  },

  // ── Step 7: 顯示拆遷隊選擇 ──
  step7(){
    // 顯示合夥人面板
    const partnerSection = document.getElementById('partner-section');
    if(partnerSection) partnerSection.style.visibility = '';
    const hasProfit = G.profit > 0;
    TUT.speak(hasProfit ? [
      '幹得好！你賺到了收益！',
      '現在，我們來介紹「合夥人」！',
      '合夥人會在整輪遊戲中持續幫助你——但通常也有負面效果。',
      '這次我們提供你一個特別的合夥人：拆遷隊。選擇它吧！',
    ] : [
      '雖然這次沒有賺到收益，但沒關係！',
      '現在，我們來介紹「合夥人」！',
      '合夥人會在整輪遊戲中持續幫助你——但通常也有負面效果。',
      '這次我們提供你一個特別的合夥人：拆遷隊。選擇它吧！',
    ], ()=>{
      // Show single partner choice: demolition only
      TUT.showTutPartnerChoice();
    });
  },

  // ── Step 8: 觸發行業熱潮，引導使用拆遷隊 ──
  step8(){
    // 清空事件預告（已觸發）
    G.nextEvent = null;
    // 顯示事件橫幅
    const evBanner = document.getElementById('ev-banner');
    if(evBanner){
      evBanner.style.visibility = '';
      evBanner.classList.add('show');
    }
    document.getElementById('ev-title').textContent = '🎲 行業熱潮';
    // Apply row_buff event manually
    G.buff = G.buff||{};
    // 隨機一行 +1
    const bonusRow = Math.floor(Math.random()*4);
    const penaltyRow = (bonusRow+2)%4;
    document.getElementById('ev-desc').textContent = `第${bonusRow+1}行設施效果+1，第${penaltyRow+1}行-1`;
    // 清空事件選項按鈕
    document.querySelector('.ev-opts').innerHTML = '';
    for(let cc=0;cc<GN();cc++){
      const k1=`${bonusRow},${cc}`;
      const k2=`${penaltyRow},${cc}`;
      G.cellMods[k1]=(G.cellMods[k1]||0)+1;
      G.cellMods[k2]=(G.cellMods[k2]||0)-1;
    }
    // 給拆遷隊次數
    G.demolitionCharges = 1;
    G.phase = 'place';
    render();
    renderPartners();
    TUT.speak([
      `🎲 行業熱潮！第${bonusRow+1}行設施效果+1，第${penaltyRow+1}行-1！`,
      '哎呀，這樣的話你的設施排列可能不太好……',
      '拆遷隊的能力可以讓你重新排列設施！點擊合夥人欄的拆遷隊來使用吧！',
    ], ()=>{
      TUT.waitingFor = 'use_demolition';
      TUT.highlightPartner('demolition');
    });
  },

  // ── Step 9: 最後說明，進入正式遊戲 ──
  step9(){
    TUT.speak([
      '很棒！看到了吧？合夥人能讓你更靈活地應對各種狀況。',
      '但記得——每個合夥人都有自己的負面效果，選擇時要仔細考慮策略！',
      '好了，基礎就這樣！正式遊戲開始，祝你好運～♡',
    ], ()=>{
      TUT.finish();
    });
  },

  finish(){
    TUT.active = false;
    TUT.waitingFor = null;
    // 補全所有 UI
    TUT.setUIVisibility(true);
    // 隱藏事件橫幅
    const evBanner = document.getElementById('ev-banner');
    if(evBanner) evBanner.classList.remove('show');
    // 清空教學狀態，進入正式遊戲
    G.tutorialMode = false;
    G.phase = 'place';
    G.turn = 1;
    G.round = 1;
    G.profit = 0;
    G.cellMods = {};
    G.buff = {};
    G.hand = [{id:'mat_factory',count:1},{id:'factory',count:1},{id:'shop',count:1}];
    G.card = {value:1, type:'money'};
    // 保留已放置的設施和合夥人
    render();
    renderFanHand();
    renderPartners();
    // 正式開始第一輪
    startRound();
  },

  // ── 輔助：顯示連續台詞 ──
  _speechQueue: [],
  _speechIdx: 0,
  speak(lines, onDone){
    TUT._speechQueue = lines;
    TUT._speechIdx = 0;
    TUT._speechDone = onDone;
    TUT._nextLine();
  },
  _nextLine(){
    if(TUT._speechIdx >= TUT._speechQueue.length){
      TUT._allowDM = false;
      if(TUT._speechDone) TUT._speechDone();
      return;
    }
    const line = TUT._speechQueue[TUT._speechIdx++];
    TUT._allowDM = true;
    DM.show(line, 3000);
    TUT._allowDM = false;
    TUT._speechTimer = setTimeout(()=>TUT._nextLine(), 3200);
  },

  bubble(text){
    TUT._allowDM = true;
    DM.show(text, 99999);
    TUT._allowDM = false;
  },

  // ── 輔助：高亮格子 ──
  highlightGrid(on){
    const grid = document.getElementById('grid');
    if(grid) grid.style.outline = on ? '3px solid var(--acc)' : '';
  },

  // ── 輔助：高亮合夥人 ──
  highlightPartner(pid){
    const cards = document.querySelectorAll('.joker-card');
    cards.forEach(card=>{
      const name = card.querySelector('.jc-name')?.textContent;
      if(name === PARTNERS[pid]?.name){
        card.style.outline = '3px solid var(--acc)';
        card.style.animation = 'pulse-acc 1s infinite';
      }
    });
  },

  // ── 教學合夥人選擇（只有拆遷隊）──
  showTutPartnerChoice(){
    const el = document.getElementById('card-chooser');
    document.getElementById('card-chooser-title').textContent = '🎮 選擇你的合夥人（教學）';
    const p = PARTNERS['demolition'];
    document.getElementById('card-chooser-cards').innerHTML =
      makeSelCard(p.emoji, p.name, p.pos, p.pos, '', `TUT.pickTutPartner('demolition')`, '', 'demolition', '');
    const skipBtn = document.getElementById('card-chooser-skip');
    if(skipBtn) skipBtn.style.display = 'none';
    el.style.display = 'flex';
  },

  pickTutPartner(pid){
    closeCardChooser();
    G.partners.push(pid);
    addLog(`🤝 獲得合夥人：${PARTNERS[pid].emoji}${PARTNERS[pid].name}！`,'g');
    // 設定事件預告（行業熱潮）- 在當前回合3觸發
    G.nextEvent = {id:'row_buff', title:'📈 行業熱潮', desc:'隨機一行設施本輪互動額外 +1，另一行 -1'};
    G.nextEventTurn = G.turn; // 當前回合觸發
    renderPartners();
    render();
    setTimeout(()=>TUT.next(), 500);
  },

  // ── 教學事件：玩家觸發特定動作時呼叫 ──
  onAction(action, data){
    if(!TUT.active) return false;
    if(TUT.waitingFor === action){
      TUT.waitingFor = null;
      setTimeout(()=>TUT.next(), 600);
      return true;
    }
    return false;
  },
};

// ── 教學詢問畫面 ──
function showTutorialPrompt(){
  const el = document.getElementById('card-chooser');
  document.getElementById('card-chooser-title').textContent = '🎮 歡迎來到創業小鎮！';
  document.getElementById('card-chooser-cards').innerHTML = `
    <div class="sel-card" onclick="startTutorial()" style="cursor:pointer;min-width:160px;">
      <div class="sel-card-emoji">📖</div>
      <div class="sel-card-name">進行教學</div>
      <div class="sel-card-desc">譚雅與蕾雅帶你一步步了解遊戲</div>
      <div class="sel-card-pos">✓ 推薦新玩家</div>
    </div>
    <div class="sel-card" onclick="skipTutorial()" style="cursor:pointer;min-width:160px;">
      <div class="sel-card-emoji">⚔️</div>
      <div class="sel-card-name">跳過教學</div>
      <div class="sel-card-desc">直接開始正式遊戲</div>
      <div class="sel-card-pos">✓ 已熟悉遊戲規則</div>
    </div>
  `;
  const skipBtn = document.getElementById('card-chooser-skip');
  if(skipBtn) skipBtn.style.display = 'none';
  el.style.display = 'flex';
}

function startTutorial(){
  closeCardChooser();
  TUT.start();
}

function skipTutorial(){
  closeCardChooser();
  showStarterPartnerSelection();
}


// BOOT
G=newGame();
// Show tutorial prompt first
showTutorialPrompt();
</script>




<div id="char-bubble"></div>

<!-- 角色立繪 -->
<div id="char-tray" onclick="charClick()" title="譚雅 & 蕾雅">
  <img src="data:image/png;base64," alt="譚雅與蕾雅">
</div>

