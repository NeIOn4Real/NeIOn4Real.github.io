function hasPartner(id){ return G.partners.some(p=>p===id); }
function hasPride(){ return hasPartner('pride'); }
function isDemonNegDisabled(){ return hasPride(); }

const TCOLOR={ money:'var(--money)', material:'var(--mat)', goods:'var(--goods)', diamond:'#5bcefa' };
const TLABEL={ money:'💰金錢', material:'🪨原料', goods:'📦商品', diamond:'💎鑽石' };
const N=4; // base grid size
function GN(){ return (G&&G.gridSize)||N; }

