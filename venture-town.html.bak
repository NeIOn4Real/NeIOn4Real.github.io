<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>創業小鎮</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;700;900&family=DM+Mono:wght@500&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#f4efe5;--bg2:#ebe3d0;--bg3:#ddd4bc;--sur:#faf7f1;
  --br:rgba(80,55,20,.13);--br2:rgba(80,55,20,.25);
  --tx:#2a1a08;--mu:rgba(42,26,8,.5);--hi:rgba(42,26,8,.28);
  --money:#b06000;--mat:#7a4e1a;--goods:#2a6e3a;
  --acc:#b33a00;--blue:#1a4e7a;--green:#2a7a3a;--red:#c0392b;
  --cell:66px;--r:10px;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Noto Sans TC',sans-serif;background:var(--bg);color:var(--tx);
  min-height:100vh;display:flex;flex-direction:column;align-items:center;padding:12px;
  background-image:repeating-linear-gradient(0deg,transparent,transparent 40px,rgba(80,55,20,.03) 40px,rgba(80,55,20,.03) 41px),
    repeating-linear-gradient(90deg,transparent,transparent 40px,rgba(80,55,20,.03) 40px,rgba(80,55,20,.03) 41px);}

/* HEADER */
#hdr{width:100%;max-width:880px;display:flex;align-items:center;gap:8px;margin-bottom:10px;flex-wrap:wrap;}
#logo{font-size:18px;font-weight:900;letter-spacing:-.5px;}
#logo span{color:var(--acc);}
.chip{display:flex;align-items:center;gap:4px;background:var(--sur);border:1px solid var(--br2);
  border-radius:99px;padding:4px 12px;font-size:12px;font-weight:700;
  box-shadow:0 1px 3px rgba(80,55,20,.07);}
.chip .v{color:var(--money);}
#profit-area{margin-left:auto;display:flex;align-items:center;gap:6px;}
#pbar{height:7px;width:100px;background:var(--bg3);border-radius:99px;overflow:hidden;border:1px solid var(--br);}
#pbar-fill{height:100%;background:var(--green);border-radius:99px;transition:width .4s;}

/* LAYOUT */
#main{width:100%;max-width:880px;display:grid;grid-template-columns:155px 1fr 220px;gap:10px;align-items:start;}
.panel{background:var(--sur);border:1px solid var(--br2);border-radius:var(--r);padding:10px 12px;box-shadow:0 2px 6px rgba(80,55,20,.05);}
.pt{font-size:10px;font-weight:700;color:var(--mu);text-transform:uppercase;letter-spacing:.7px;
  padding-bottom:6px;border-bottom:1px solid var(--br);margin-bottom:8px;}

/* EVENT BANNER */
#ev-banner{width:100%;max-width:880px;background:var(--sur);border:1px solid var(--br2);
  border-radius:var(--r);padding:10px 14px;margin-bottom:10px;display:none;
  box-shadow:0 2px 8px rgba(80,55,20,.07);}
#ev-banner.show{display:block;}
#ev-title{font-size:12px;font-weight:700;margin-bottom:3px;}
#ev-desc{font-size:11px;color:var(--mu);margin-bottom:8px;}
.ev-opts{display:flex;gap:6px;flex-wrap:wrap;}
.eopt{padding:6px 14px;border-radius:99px;border:1px solid var(--br2);background:var(--bg2);
  font-size:11px;font-weight:700;cursor:pointer;transition:all .15s;font-family:'Noto Sans TC',sans-serif;}
.eopt:hover{background:var(--bg);border-color:var(--acc);color:var(--acc);}
.eopt.pri{background:var(--acc);color:#fff;border-color:var(--acc);}

/* GRID */
#grid-area{display:flex;flex-direction:column;align-items:center;gap:2px;}
.drow{display:flex;gap:2px;}
.dcol-wrap{display:flex;align-items:center;gap:2px;}
.dside{display:flex;flex-direction:column;gap:2px;}
.dbtn{
  width:var(--cell);height:26px;background:transparent;border:2px dashed transparent;
  border-radius:6px;cursor:pointer;font-size:16px;font-weight:900;color:transparent;
  transition:all .2s;display:flex;align-items:center;justify-content:center;
  font-family:'Noto Sans TC',sans-serif;pointer-events:none;opacity:0;
}
.dbtn.side{width:26px;height:var(--cell);}
/* 拖曳中才顯示箭頭 */
body.card-dragging .dbtn:not(.wind-blocked){
  opacity:1;pointer-events:auto;color:var(--acc);
  border-color:rgba(179,58,0,.25);background:rgba(179,58,0,.05);
}
/* 場風/颱風限制方向：拖曳中也保持隱藏 */
body.card-dragging .dbtn.wind-blocked{
  opacity:0 !important;pointer-events:none !important;
}
/* 允許方向：加強顯示 */
body.card-dragging .dbtn.wind-active{
  opacity:1;pointer-events:auto;
  color:var(--acc);border-color:var(--acc);
  background:rgba(179,58,0,.12);
  animation:windPulse 1s ease-in-out infinite;
}
@keyframes windPulse{
  0%,100%{ box-shadow:0 0 0 0 rgba(179,58,0,.3); }
  50%{ box-shadow:0 0 0 6px rgba(179,58,0,.0); }
}
body.card-dragging .dbtn:hover:not(.wind-blocked),
.dbtn.drag-over{
  background:rgba(42,122,58,.18)!important;border-color:var(--green)!important;
  color:var(--green)!important;transform:scale(1.15);opacity:1;pointer-events:auto;
}
.dbtn:disabled{opacity:0!important;pointer-events:none;}
#grid{display:grid;gap:2px;background:var(--bg3);border:2px solid var(--br2);
  border-radius:var(--r);padding:4px;box-shadow:0 4px 14px rgba(80,55,20,.1);}
.cell{width:var(--cell);height:var(--cell);background:var(--bg2);border:1px solid var(--br);
  border-radius:6px;display:flex;flex-direction:column;align-items:center;justify-content:center;
  cursor:pointer;transition:all .15s;position:relative;user-select:none;}
.cell:hover:not(.filled){background:var(--bg);border-color:var(--br2);}
.cell.filled{background:var(--bg);border-color:var(--br2);cursor:default;}
.cell.filled:hover{background:var(--bg);}
.cell.pulse{animation:pulse .45s ease;}
@keyframes pulse{0%,100%{transform:scale(1)}50%{transform:scale(1.07)}}
.cemoji{font-size:22px;line-height:1;}
.cname{font-size:8px;color:var(--mu);margin-top:1px;}

/* HAND */
.hi{display:flex;align-items:center;gap:7px;padding:6px 8px;border-radius:7px;
  background:var(--bg2);border:1px solid var(--br);cursor:pointer;transition:all .15s;margin-bottom:4px;}
.hi:hover{background:var(--bg);border-color:var(--br2);}
.hi.sel{background:rgba(179,58,0,.1);border-color:var(--acc);}
.hi.off{opacity:.35;cursor:not-allowed;pointer-events:none;}
.hi-em{font-size:18px;flex-shrink:0;}
.hi-nm{font-size:11px;font-weight:700;}
.hi-ds{font-size:9px;color:var(--mu);line-height:1.3;}
.hi-ct{font-size:10px;font-weight:700;color:var(--acc);margin-left:auto;}

/* BTNS */
.abtn{width:100%;padding:9px 12px;border:1px solid var(--br2);border-radius:var(--r);
  background:var(--sur);color:var(--tx);font-size:12px;font-weight:700;
  font-family:'Noto Sans TC',sans-serif;cursor:pointer;transition:all .15s;
  text-align:left;margin-bottom:5px;}
.abtn:hover:not(:disabled){background:var(--bg2);}
.abtn.pri{background:var(--acc);color:#fff;border-color:var(--acc);}
.abtn.pri:hover{opacity:.88;}
.abtn:disabled{opacity:.28;cursor:not-allowed;}

/* LOG */
 /* hidden - replaced by side log */
#side-log{
  background:var(--sur);border:1px solid var(--br);
  border-radius:var(--r);padding:8px 10px;
  height:100%;overflow-y:auto;font-size:10px;
  min-height:200px;
}
.log-turn-block{ margin-bottom:10px; }
.log-turn-hdr{ font-size:10px;font-weight:700;color:var(--acc);margin-bottom:3px;padding-bottom:3px;border-bottom:1px solid var(--br); }
.log-entry{ line-height:1.6;color:var(--mu);padding-left:4px; }
.log-entry.g{ color:var(--green); }
.log-entry.b{ color:var(--red); }
.log-entry.w{ color:var(--money); }
.log-entry.h{ color:var(--tx);font-weight:700; }
.log-calc{ font-family:'DM Mono',monospace;font-size:9px;color:var(--blue);padding-left:8px; }

/* MODAL */
#modal{display:none;position:fixed;inset:0;z-index:100;background:rgba(42,26,8,.55);
  align-items:center;justify-content:center;}
#modal.show{display:flex;}
#mbox{background:var(--sur);border:1px solid var(--br2);border-radius:14px;padding:28px 24px;
  text-align:center;max-width:300px;width:90%;box-shadow:0 8px 28px rgba(42,26,8,.18);
  animation:min .3s cubic-bezier(.34,1.56,.64,1);}
@keyframes min{from{transform:scale(.7);opacity:0}}
#memo{font-size:38px;margin-bottom:8px;}
#mtitle{font-size:20px;font-weight:900;margin-bottom:6px;}
#mmsg{font-size:11px;color:var(--mu);margin-bottom:16px;line-height:1.7;white-space:pre-line;}
#mbtn{padding:9px 24px;border-radius:99px;border:none;font-size:12px;font-weight:700;
  font-family:'Noto Sans TC',sans-serif;cursor:pointer;background:var(--acc);color:#fff;}

/* DELTA */
.delta{position:fixed;pointer-events:none;font-size:14px;font-weight:900;z-index:200;
  animation:fup .9s ease forwards;}
@keyframes fup{0%{opacity:1;transform:translateY(0)}100%{opacity:0;transform:translateY(-44px)}}
/* ── 元素卡牌 ── */





@keyframes cardPulse{0%,100%{transform:scale(1)}50%{transform:scale(1.08)}}






/* ── 拖曳目標高亮 ── */
.dbtn.drag-over{background:rgba(42,122,58,.2)!important;border-color:var(--green)!important;
  color:var(--green)!important;transform:scale(1.1);}
.cell.drag-target{background:rgba(179,58,0,.1);border-color:var(--acc);border-style:dashed;}
.cell.drag-over-cell{background:rgba(42,122,58,.12);border-color:var(--green);}

/* ── 元素移動動畫 ── */
#el-mover{
  position:fixed;width:56px;height:66px;
  background:linear-gradient(145deg,var(--sur),var(--bg2));
  border:2px solid var(--acc);border-radius:8px;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  gap:2px;pointer-events:none;z-index:500;
  box-shadow:0 4px 14px rgba(179,58,0,.3);
  transition:left .32s cubic-bezier(.4,0,.2,1),top .32s cubic-bezier(.4,0,.2,1);
}
#el-mover .mv-emoji{font-size:16px;line-height:1;}
#el-mover .mv-val{font-size:14px;font-weight:900;font-family:'DM Mono',monospace;}
#el-mover .mv-type{font-size:7px;color:var(--mu);}

/* ── 收益飛行動畫 ── */
.profit-fly{
  position:fixed;pointer-events:none;z-index:600;
  font-size:20px;font-weight:900;color:var(--green);
  text-shadow:0 2px 8px rgba(42,122,58,.4);
  animation:profitFly 1.2s cubic-bezier(.4,0,.2,1) forwards;
}
@keyframes profitFly{
  0%{opacity:0;transform:scale(.5) translateY(0);}
  20%{opacity:1;transform:scale(1.2) translateY(-20px);}
  80%{opacity:1;}
  100%{opacity:0;transform:scale(.6) translateY(-120px) translateX(var(--tx,0px));}
}

/* ── 格子閃光 ── */
.cell.active-path{
  background:rgba(179,58,0,.08);
  border-color:rgba(179,58,0,.4);
  box-shadow:0 0 0 2px rgba(179,58,0,.2);
}
.cell.transform-flash{animation:tflash .5s ease;}
@keyframes tflash{0%{background:rgba(42,122,58,.2)}100%{background:inherit}}

/* ── 數值變化標籤 ── */
.change-badge{
  position:absolute;top:-18px;left:50%;transform:translateX(-50%);
  background:var(--green);color:#fff;border-radius:99px;
  padding:2px 8px;font-size:10px;font-weight:700;white-space:nowrap;
  animation:badgePop .5s ease forwards;pointer-events:none;z-index:10;
}
@keyframes badgePop{0%{opacity:0;transform:translateX(-50%) scale(.5)}
  60%{opacity:1;transform:translateX(-50%) scale(1.1)}
  100%{opacity:1;transform:translateX(-50%) scale(1)}}

/* 行動選項 */
.act-opt{width:100%;padding:7px 10px;margin-bottom:5px;border-radius:8px;
  border:1px solid var(--br2);background:var(--bg2);cursor:pointer;
  font-family:'Noto Sans TC',sans-serif;text-align:left;transition:all .15s;}
.act-opt:hover:not(:disabled){background:var(--bg);border-color:var(--acc);}
.act-opt:disabled{opacity:.3;cursor:not-allowed;}
.act-opt-label{font-size:11px;font-weight:700;display:flex;justify-content:space-between;align-items:center;}
.act-opt-desc{font-size:9px;color:var(--mu);margin-top:2px;}
.act-cost{color:var(--acc);font-size:10px;font-weight:700;white-space:nowrap;}
.act-cost.free{color:var(--green);}
.cell.upgrade-glow{
  border-color:var(--money)!important;
  box-shadow:0 0 0 2px rgba(176,96,0,.3), 0 0 10px rgba(176,96,0,.2);
  animation:upgradeGlow 1.2s ease-in-out infinite;
  cursor:pointer!important;
}
@keyframes upgradeGlow{0%,100%{box-shadow:0 0 0 2px rgba(176,96,0,.3)}50%{box-shadow:0 0 0 3px rgba(176,96,0,.6),0 0 14px rgba(176,96,0,.3)}}
.upgrade-hint{width:100%;max-width:880px;background:rgba(176,96,0,.1);border:1px solid rgba(176,96,0,.3);
  border-radius:8px;padding:7px 14px;margin-bottom:8px;font-size:11px;font-weight:700;color:var(--money);display:none;}
.upgrade-hint.show{display:block;}
.acard{width:160px;background:var(--sur);border:1.5px solid var(--br2);border-radius:14px;padding:16px 14px;
  display:flex;flex-direction:column;gap:7px;transition:all .15s;
  box-shadow:0 8px 28px rgba(42,26,8,.18),0 2px 6px rgba(42,26,8,.08);opacity:1;}
.acard:hover:not(.acard-disabled){border-color:var(--acc);transform:translateY(-4px);box-shadow:0 14px 36px rgba(179,58,0,.22);}
.acard-disabled{opacity:1;pointer-events:none;border-color:var(--red);background:var(--bg2);}
.acard-disabled .acard-label{color:var(--mu);}
.acard-disabled .acard-desc{color:var(--hi);}
.acard-disabled .acard-cost{color:var(--red);}
.acard-label{font-size:12px;font-weight:700;color:var(--tx);}
.acard-desc{font-size:9px;color:var(--mu);line-height:1.5;flex:1;}
.acard-cost{font-size:11px;font-weight:700;color:var(--acc);text-align:right;}
.acard-cost.free{color:var(--green);}
/* 格子增幅標記 */
.cell-mod-pos{position:absolute;bottom:2px;right:3px;font-size:9px;font-weight:900;color:var(--green);}
.cell-mod-neg{position:absolute;bottom:2px;right:3px;font-size:9px;font-weight:900;color:var(--red);}
/* 合夥人卡片 */
.partner-card{
  flex-shrink:0;width:72px;
  background:var(--sur);border:1px solid var(--br2);border-radius:10px;
  padding:8px 6px;text-align:center;
  box-shadow:0 2px 8px rgba(42,26,8,.1);
  transition:transform .15s;cursor:default;
}
.partner-card:hover{transform:translateY(-2px);}
.partner-card .pc-emoji{font-size:20px;line-height:1;margin-bottom:3px;}
.partner-card .pc-name{font-size:8px;font-weight:700;color:var(--tx);line-height:1.2;}
.partner-card .pc-pos{font-size:7px;color:var(--green);margin-top:2px;line-height:1.3;}
.partner-card .pc-neg{font-size:7px;color:var(--red);margin-top:1px;line-height:1.3;}



/* 浮動說明視窗 */
#tooltip{
  position:fixed;z-index:9999;pointer-events:none;
  background:var(--tx);color:var(--bg);
  border-radius:8px;padding:8px 12px;
  font-size:10px;line-height:1.6;max-width:200px;
  box-shadow:0 4px 16px rgba(0,0,0,.25);
  opacity:0;transition:opacity .15s;
  white-space:pre-wrap;
}
#tooltip.show{opacity:1;}

/* 選擇卡片（設施/合夥人） */
.sel-card{
  width:180px;flex-shrink:0;
  min-height:200px;
  background:var(--sur);border:1.5px solid var(--br2);border-radius:12px;
  padding:14px 12px;cursor:pointer;
  display:flex;flex-direction:column;align-items:center;gap:4px;
  box-shadow:0 4px 14px rgba(42,26,8,.12);
  transition:all .15s;
  text-align:center;
}
.sel-card:hover{border-color:var(--acc);transform:translateY(-3px);box-shadow:0 8px 20px rgba(179,58,0,.18);}
.sel-card-emoji{font-size:24px;line-height:1;margin-bottom:2px;}
.sel-card-name{font-size:12px;font-weight:700;color:var(--tx);text-align:center;width:100%;}
.sel-card-desc{font-size:9px;color:var(--mu);line-height:1.4;flex:1;text-align:center;width:100%;}
.sel-card-pos{font-size:8px;color:var(--green);margin-top:2px;}
.sel-card-neg{font-size:8px;color:var(--red);margin-top:1px;}
/* partner card hover tooltip */
.partner-card{position:relative;}

/* ══ 扇形手牌系統 ══ */
#hand-fan-area {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  height: 150px;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
  z-index: 60;
  background: linear-gradient(to top, rgba(244,239,229,0.98) 75%, transparent);
  overflow: visible;
}

/* 卡牌基底 */
.fan-card {
  position: relative;
  flex-shrink: 0;
  width: 76px;
  height: 105px;
  border-radius: 10px;
  cursor: pointer;
  pointer-events: auto;
  transform-origin: center bottom;
  transition: transform 0.22s cubic-bezier(.4,0,.2,1), box-shadow 0.2s;
  user-select: none;
  will-change: transform;
  margin: 0 -8px;
}

/* 卡牌內容容器 */


.fan-card:hover {
  transform: translateY(-55px) rotate(0deg) scale(1.1) !important;
  z-index: 200 !important;
}
.fan-card.event-card 
.fan-card.event-card 
.fan-card.el-card-fan 
.fan-card.el-card-fan 
.fan-card.talent-card {
  border-color: var(--money);
  background: linear-gradient(145deg, #fff9ee, #fff3d4);
}

.fan-card .fc-emoji { font-size: 20px; line-height: 1; z-index: 1; }
.fan-card .fc-name  { font-size: 8px; font-weight: 700; text-align: center; line-height: 1.3; color: var(--tx); }
.fan-card .fc-desc  { font-size: 7px; color: var(--mu); text-align: center; line-height: 1.3; }
.fan-card .fc-count { font-size: 9px; font-weight: 700; color: var(--acc); }
.fan-card .fc-val   { font-size: 14px; font-weight: 900; color: var(--green); font-family: 'DM Mono', monospace; }
.fan-card .fc-type  { font-size: 8px; color: var(--mu); }


/* 燃燒消失動畫 */
@keyframes burnAway {
  0%   { opacity:1; transform: translateY(-55px) scale(1.1); filter: brightness(1); }
  40%  { opacity:.9; transform: translateY(-90px) scale(1.12); filter: brightness(1.6) sepia(1) saturate(4); }
  100% { opacity:0; transform: translateY(-150px) scale(.7); filter: brightness(2) sepia(1) saturate(6) blur(4px); }
}
.fan-card.burning {
  animation: burnAway 0.7s ease-out forwards !important;
  pointer-events: none;
}

/* main area bottom padding so content isn't hidden by hand */
body { padding-bottom: 150px; }


/* ── 合夥人卡片（小丑牌風格） ── */
#partner-section {
  width:100%;max-width:880px;
  margin-bottom:8px;
  padding:0 4px;
}
#partner-section-title {
  font-size:10px;font-weight:700;color:var(--mu);
  letter-spacing:.6px;text-transform:uppercase;
  margin-bottom:5px;padding-left:2px;
}
#partner-row {
  display:flex;gap:0;
  overflow-x:auto;overflow-y:visible;
  padding:8px 4px 12px;
  scrollbar-width:none;
  scroll-behavior:smooth;
}
#partner-row::-webkit-scrollbar{display:none;}
.joker-card {
  flex-shrink:0;
  width:64px;height:88px;
  background:linear-gradient(160deg,#fff9f2,var(--sur));
  border:1.5px solid var(--br2);
  border-radius:10px;
  display:flex;flex-direction:column;
  align-items:center;justify-content:center;
  gap:4px;
  margin-right:-12px;
  cursor:default;
  position:relative;
  box-shadow:2px 2px 8px rgba(42,26,8,.13),0 1px 3px rgba(42,26,8,.08);
  transition:transform .15s, z-index 0s, box-shadow .15s;
  z-index:1;
}
.joker-card:hover {
  transform:translateY(-14px) scale(1.06);
  z-index:50;
  box-shadow:4px 6px 18px rgba(42,26,8,.22);
}
.joker-card .jc-emoji { font-size:28px;line-height:1; }
.joker-card .jc-avatar { width:40px;height:40px;border-radius:50%;object-fit:cover;object-position:top center; }
.joker-card .jc-name  { font-size:7px;font-weight:700;color:var(--tx);text-align:center;line-height:1.2;padding:0 3px; }
.joker-card.demon { border-color:#c0392b; background:linear-gradient(160deg,#fff5f5,#fff0ee); }
.joker-card.demon .jc-name { color:#c0392b; }






/* ── 角色立繪（右下角） ── */
#char-tray {
  position: fixed;
  bottom: 0px;
  right: 0px;
  z-index: 98;
  pointer-events: none;
  width: clamp(300px, 30vw, 500px);
}

/* ── 對話泡泡 ── */
#char-bubble {
  position: fixed;
  /* 人物寬度右對齊，底部對齊人物頭頂（圖片高度約為寬度*0.93，頭部約在頂部20%） */
  right: 10px;
  bottom: calc(clamp(300px, 30vw, 500px) * 0.93 + 60px);
  max-width: 240px;
  background: #fff;
  border: 2px solid var(--br2);
  border-radius: 16px 16px 16px 4px;
  padding: 10px 14px;
  font-size: 12px;
  line-height: 1.6;
  color: var(--tx);
  box-shadow: 0 4px 16px rgba(42,26,8,.15);
  z-index: 99;
  pointer-events: none;
  opacity: 0;
  transform: translateY(6px) scale(0.96);
  transition: opacity .22s ease, transform .22s ease;
  word-break: break-word;
}
#char-bubble.show {
  opacity: 1;
  transform: translateY(0) scale(1);
}
/* 泡泡尾巴朝右下（指向人物） */
#char-bubble::after {
  content: '';
  position: absolute;
  bottom: -10px;
  right: 20px;
  border: 6px solid transparent;
  border-top-color: var(--br2);
}
#char-bubble::before {
  content: '';
  position: absolute;
  bottom: -7px;
  right: 21px;
  border: 5px solid transparent;
  border-top-color: #fff;
  z-index: 1;
}
/* 人物發光效果 */
#char-tray img {
  width: 100%;
  display: block;
  pointer-events: auto;
  cursor: pointer;
  filter: drop-shadow(-3px 0 12px rgba(0,0,0,.18));
  transition: transform .2s ease, filter .3s ease;
}

#char-tray:hover img {
  transform: translateY(-8px) scale(1.02);
}

/* 合夥人頭像卡片 */
.sel-card-avatar {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  object-fit: cover;
  object-position: top center;
  margin-bottom: 6px;
  flex-shrink: 0;
}


@keyframes pulse-acc {
  0%,100%{ box-shadow:0 0 0 0 rgba(179,58,0,.4); }
  50%{ box-shadow:0 0 0 8px rgba(179,58,0,0); }
}
</style>
</head>
<body>

<div id="hdr">
  <div id="logo">創業<span>小鎮</span></div>
  <div class="chip" style="color:var(--blue);">回合 <span class="v" id="r-turn" style="color:var(--blue);">1/15</span></div>
  <div id="profit-area">
    <div class="chip">收益 <span class="v" id="r-profit">0</span>/<span id="r-goal">30</span></div>
    <div id="pbar"><div id="pbar-fill" style="width:0%"></div></div>
  </div>
</div>

<div id="ev-banner">
  <div id="ev-title"></div>
  <div id="ev-desc"></div>
  <div class="ev-opts" id="ev-opts"></div>
</div>


<div id="upgrade-hint" class="upgrade-hint">⬆ 點擊想要提升的設施（永久 +1 輸出）</div>
<div id="wind-hint" style="display:none;width:100%;max-width:880px;border-radius:8px;
  padding:8px 16px;margin-bottom:8px;background:rgba(26,78,122,.1);border:1px solid rgba(26,78,122,.25);
  font-size:12px;font-weight:700;color:var(--blue);display:none;align-items:center;gap:8px;">
  <span style="font-size:20px;">🌀</span>
  <span id="wind-hint-text">場風大師：本回合只能從 ← 投入</span>
  <span id="wind-dir-arrow" style="font-size:24px;margin-left:4px;">←</span>
</div>

<div id="main">
  <div class="panel">
    <div class="pt">手牌設施</div>
    <div id="hand-list"></div>
    <div class="pt" style="margin-top:8px;" id="talent-section-title">人材</div>
    <div id="talent-panel" style="display:flex;flex-wrap:wrap;gap:4px;margin-bottom:6px;min-height:20px;">
      <div style="font-size:9px;color:var(--hi);padding:4px 0;">尚無人材</div>
    </div>
    <div class="pt" style="margin-top:8px;">提示</div>
    <div style="font-size:10px;color:var(--mu);line-height:1.6;">
      收益 = 元素離開金錢值 − 進入值(1)<br>
      送入前可先放設施
    </div>
  </div>

  <div id="grid-area"></div>

  <div class="panel">
    <div class="pt">本次收益</div>
    <div id="el-profit" style="font-size:15px;font-weight:700;color:var(--money);">—</div>
    <div class="pt" style="margin-top:8px;">回合記錄</div>
    <div id="side-log" style="max-height:260px;overflow-y:auto;"></div>
    <div style="margin-top:8px;"></div>
    <button class="abtn" id="btn-next" onclick="doNext()" disabled>⏩ 結束回合</button>
  </div>
</div>

<div id="partner-section" style="width:100%;max-width:880px;margin-bottom:8px;">
  <div id="partner-section-title">合夥人</div>
  <div id="partner-row"></div>
</div>


<!-- 扇形手牌區域 -->
<div id="hand-fan-area"></div>


<!-- ACTION CHOOSER MODAL -->
<div id="tooltip"></div>
<div id="action-chooser" style="display:none;position:fixed;inset:0;z-index:90;align-items:center;justify-content:center;flex-direction:column;gap:14px;">
  <!-- 透明遮罩擋住後層操作 -->
  <div style="position:absolute;inset:0;pointer-events:auto;"></div>
  <div style="position:relative;z-index:1;font-size:11px;font-weight:700;color:var(--tx);letter-spacing:.5px;opacity:.7;pointer-events:none;">⚡ 本回合行動（選一）</div>
  <div id="action-cards" style="position:relative;z-index:1;display:flex;gap:16px;justify-content:center;pointer-events:auto;"></div>
  <button onclick="closeActionOverlay()" style="position:relative;z-index:1;pointer-events:auto;padding:5px 20px;border-radius:99px;border:1px solid var(--br2);
    background:var(--bg2);color:var(--mu);font-size:10px;cursor:pointer;
    font-family:'Noto Sans TC',sans-serif;">✕ 放棄選擇</button>
</div>

<!-- 通用卡牌選擇 overlay（設施/合夥人） -->
<div id="card-chooser" style="display:none;position:fixed;inset:0;z-index:95;align-items:center;justify-content:center;flex-direction:column;gap:14px;">
  <div style="position:absolute;inset:0;pointer-events:auto;background:rgba(42,26,8,.35);"></div>
  <div id="card-chooser-title" style="position:relative;z-index:1;font-size:13px;font-weight:700;color:#fff;letter-spacing:.5px;pointer-events:none;text-shadow:0 1px 4px rgba(0,0,0,.4);margin-bottom:4px;"></div>
  <div id="card-chooser-cards" style="position:relative;z-index:1;display:flex;flex-direction:row;gap:14px;justify-content:center;align-items:stretch;pointer-events:auto;max-width:680px;flex-wrap:nowrap;"></div>
  <button id="card-chooser-skip" style="position:relative;z-index:1;pointer-events:auto;padding:5px 20px;border-radius:99px;border:1px solid rgba(255,255,255,.3);background:rgba(255,255,255,.15);color:#fff;font-size:10px;cursor:pointer;font-family:'Noto Sans TC',sans-serif;margin-top:4px;">✕ 跳過</button>
</div>
<div id="el-mover" style="display:none;">
  <div class="mv-emoji">💵</div>
  <div class="mv-val">1</div>
  <div class="mv-type">💰 金錢</div>
</div>
<div id="modal">
  <div id="mbox">
    <div id="memo">🎉</div>
    <div id="mtitle"></div>
    <div id="mmsg"></div>
    <button id="mbtn" onclick="onMBtn()">重新開始</button>
  </div>
</div>

<script>
// ══════════════════════════════════════
// 設施資料庫
// ══════════════════════════════════════
const BLDG = {
  mat_factory:{ name:'原料廠', emoji:'⛏️', desc:'金錢→原料 +1', req:'money',    out:'material', fn:v=>v+1 },
  factory:    { name:'工廠',   emoji:'🏭', desc:'原料→商品 +1', req:'material', out:'goods',    fn:v=>v+1 },
  shop:       { name:'商店',   emoji:'🏪', desc:'商品→金錢 +1', req:'goods',    out:'money',    fn:v=>v+1 },
  refinery:   { name:'精煉廠', emoji:'🔩', desc:'原料→原料 +2', req:'material', out:'material', fn:v=>v+2 },
  warehouse:  { name:'倉庫',   emoji:'📦', desc:'商品→商品 +2', req:'goods',    out:'goods',    fn:v=>v+2 },
  booster:    { name:'增幅器', emoji:'⚡', desc:'任意 +2',      req:'any',      out:null,       fn:v=>v+2 },
  converter:  { name:'轉化器', emoji:'🔄', desc:'任意→金錢',    req:'any',      out:'money',    fn:v=>v   },

  // ── 累積人力流設施 ──
  talent_training:{ name:'人力訓練中心', emoji:'🎓', desc:'每回合開始產生1人材', req:'any', out:null, fn:v=>v, special:'talent_training' },
  labor_convert:  { name:'勞動轉換站',   emoji:'⚙️', desc:'消耗2人材，資源×2', req:'any', out:null, fn:v=>v, special:'labor_convert' },
  talent_storage: { name:'人材倉庫',     emoji:'🗃️', desc:'持有5+人材時額外+5', req:'any', out:null, fn:v=>v, special:'talent_storage' },
  talent_market:  { name:'人才市場',     emoji:'🏦', desc:'任意資源→人材幣，過商店×3金錢', req:'any', out:'talent_coin', fn:v=>v, special:'talent_market' },
  overtime:       { name:'加班辦公室',   emoji:'💼', desc:'使用人材時路徑延長1格', req:'any', out:null, fn:v=>v, special:'overtime' },
  talent_bank:    { name:'人力銀行',     emoji:'🏧', desc:'金錢通過時儲存10%為加成，下次投入釋放', req:'money', out:'money', fn:v=>v, special:'talent_bank' },
  dispatch_hq:    { name:'派遣總部',     emoji:'🏢', desc:'商品通過時獲得2人材', req:'goods', out:'goods', fn:v=>v, special:'dispatch_hq' },
  strike_board:   { name:'集體罷工台',   emoji:'📢', desc:'消耗所有人材，每個+10數值（主動觸發）', req:'any', out:null, fn:v=>v, special:'strike_board' },

  // ── 物流中心流設施 ──
  spiral_hub:     { name:'螺旋物流站',   emoji:'🔄', desc:'每通過1個設施+2', req:'any', out:null, fn:v=>v, special:'spiral_hub' },
  terminal:       { name:'終點站',       emoji:'🏁', desc:'資源通過時+（已通過設施數×2）', req:'any', out:null, fn:v=>v, special:'terminal' },
  logistics_amp:  { name:'物流放大器',   emoji:'📡', desc:'通過物流後下一設施效果×2', req:'any', out:null, fn:v=>v, special:'logistics_amp' },
  transfer_hub:   { name:'轉運中心',     emoji:'🔀', desc:'放置時決定方向的物流中心（可選4向）', req:'any', out:null, fn:v=>v, special:'redirect', dir:'right' },
  speed_station:  { name:'速遞站',       emoji:'⚡', desc:'通過後若下一格有設施立即再觸發一次', req:'any', out:null, fn:v=>v, special:'speed_station' },
  logistics_vault:{ name:'物流倉',       emoji:'🏪', desc:'儲存通過時數值的50%，下次投入時作為加成釋放', req:'any', out:null, fn:v=>v, special:'logistics_vault' },
  env_sensor:     { name:'環境感應站',   emoji:'📊', desc:'周圍4格每有一個設施+1', req:'any', out:null, fn:v=>v, special:'env_sensor' },

  // ── 貿易流設施 ──
  trade_port:     { name:'外貿港口',     emoji:'⚓', desc:'商品>10時+10%，>20時+20%（每10一階）', req:'goods', out:'goods', fn:v=>v, special:'trade_port' },
  exchange_board: { name:'匯率波動板',   emoji:'📈', desc:'不參與投入路徑；每次投入結算時，隨機對最終收益加成或衰減±3~15%', req:'any', out:null, fn:v=>v, special:'exchange_board' },
  futures_market: { name:'期貨交易所',   emoji:'🏛', desc:'放置時鎖定當前倍率，永久使用', req:'goods', out:'money', fn:v=>v, special:'futures_market' },
  trade_zone:     { name:'貿易特區',     emoji:'🌏', desc:'周圍4格有商店時輸出×1.5', req:'any', out:null, fn:v=>v, special:'trade_zone' },
  clearance:      { name:'清倉拍賣場',   emoji:'🏷️', desc:'商品數值清零，獲得等值×4金錢', req:'goods', out:'money', fn:v=>v*4, special:'clearance' },
  import_tax:     { name:'進出口稅站',   emoji:'🧾', desc:'扣除1金錢（從收益），本格效果×2', req:'any', out:null, fn:v=>v, special:'import_tax' },
  free_market:    { name:'自由市場',     emoji:'🗽', desc:'任意資源進入，輸出金錢（當前數值）', req:'any', out:'money', fn:v=>v },

  // ── 拆遷流設施 ──
  bomb_device:    { name:'爆破裝置',     emoji:'💣', desc:'3回合後自動爆炸消滅自身，周圍4格+3', req:'any', out:null, fn:v=>v, special:'bomb_device' },
  demolish_fab:   { name:'建築廢料廠',   emoji:'🏗', desc:'資源通過時消滅自身，本次投入×2', req:'any', out:null, fn:v=>v, special:'demolish_fab' },
  temp_shed:      { name:'臨時工棚',     emoji:'🛖', desc:'每移動一次輸出+1（最高+5）', req:'any', out:null, fn:v=>v, special:'temp_shed' },
  magnet_plate:   { name:'磁力板',       emoji:'🧲', desc:'每回合開始與相鄰隨機設施交換位置', req:'any', out:null, fn:v=>v, special:'magnet_plate' },
  ruin_monument:  { name:'廢墟紀念碑',   emoji:'🗿', desc:'只能放在有設施被消滅的格子，輸出+5', req:'any', out:null, fn:v=>Math.max(0,v+5), special:'ruin_monument', ruinOnly:true },
  demolish_bureau:{ name:'拆遷補償局',   emoji:'🏢', desc:'每次移動或消滅設施+1收益', req:'any', out:null, fn:v=>v, special:'demolish_bureau' },
  dynamic_amp:    { name:'動態加強器',   emoji:'🔋', desc:'本回合設施被移動過，此設施輸出×2', req:'any', out:null, fn:v=>v, special:'dynamic_amp' },
  unstable_base:  { name:'地基不穩定站', emoji:'⚠️', desc:'相鄰有減益時輸出翻倍；相鄰有增益時-1', req:'any', out:null, fn:v=>v, special:'unstable_base' },

  envy_factory:{ name:'嫉妒工廠', emoji:'💚', desc:'金錢→1鑽石，鑽石過商店×12', req:'money', out:'diamond', fn:v=>1, special:'envy' },
  logistics_up:   { name:'物流↑', emoji:'⬆️', desc:'轉向：向上繼續', req:'any', out:null, fn:v=>v, special:'redirect', dir:'top'    },
  logistics_down: { name:'物流↓', emoji:'⬇️', desc:'轉向：向下繼續', req:'any', out:null, fn:v=>v, special:'redirect', dir:'bottom' },
  logistics_left: { name:'物流←', emoji:'⬅️', desc:'轉向：向左繼續', req:'any', out:null, fn:v=>v, special:'redirect', dir:'left'   },
  logistics_right:{ name:'物流→', emoji:'➡️', desc:'轉向：向右繼續', req:'any', out:null, fn:v=>v, special:'redirect', dir:'right'  },
  cafeteria:{ name:'員工食堂', emoji:'🍱', desc:'投入商品時額外獲得1人材', req:'goods', out:'goods', fn:v=>v, special:'cafeteria' },
  staffing:  { name:'人力派遣', emoji:'🏢', desc:'金錢投入時獲得1人材（不消耗收益）', req:'money', out:'money', fn:v=>v, special:'staffing' },
  trade_hub: { name:'貿易代理', emoji:'🌐', desc:'中央專屬。金錢→1%原料；商品→1%金錢', req:'any', out:null, fn:v=>v, special:'trade_hub', centerOnly:true },
  tech_lab:  { name:'科技研發', emoji:'🔬', desc:'中央專屬。商品投入時獲得2%商品', req:'goods', out:'goods', fn:v=>Math.floor(v*1.02), special:'tech_lab', centerOnly:true },
  tax_office:{ name:'稅務局', emoji:'🏛', desc:'每回合開始隨機設施升級，最終收益-10%', req:'any', out:null, fn:v=>v, special:'tax_office' },
};

// ══════════════════════════════════════
// 合夥人定義
// ══════════════════════════════════════
const PARTNERS = {
  poverty_god: {
    id:'poverty_god', name:'貧窮神', emoji:'🪙', isDemon:true,
    pos:'收益為零時 +bonus（bonus逐次累積）',
    neg:'獲得收益時，bonus重置為1',
    desc:'貧窮神',
    state: { bonus:1 },
    onFinish(G, profit){
      const st = G.partnerState.poverty_god || { bonus:1 };
      if(profit === 0){
        G.profit += st.bonus;
        addLog(`🪙 貧窮神：收益為零，獲得 +${st.bonus}`, 'g');
      setTimeout(()=>profitFlyFromPartner('poverty_god',st.bonus),100);
        st.bonus++;
      } else {
        if(st.bonus > 1) addLog(`🪙 貧窮神：bonus重置回1`);
        st.bonus = 1;
      }
      G.partnerState.poverty_god = st;
    }
  },
  gluttony: {
    id:'gluttony', name:'暴食惡魔', emoji:'👹', isDemon:true,
    pos:'投入時原料視為商品，商品視為原料',
    neg:'回合開始時，資源為商品或原料時減少10%',
    desc:'暴食惡魔',
    onRoundStart(G){
      if(G.card.type==='material'||G.card.type==='goods'){
        G.card.value = Math.floor(G.card.value * 0.9);
        addLog(`👹 暴食惡魔：回合開始資源-10%，現在 ${G.card.value}`,'b');
        updateCard(G.card);
      }
    },
    modifyCard(el){
      if(el.type==='material') return {...el,type:'goods'};
      if(el.type==='goods') return {...el,type:'material'};
      return el;
    }
  },
  sloth: {
    id:'sloth', name:'怠惰惡魔', emoji:'😴', isDemon:true,
    pos:'放棄選擇時，2/3機率資源+10',
    neg:'放棄選擇時，1/3機率資源變成1',
    desc:'怠惰惡魔',
    onSkipAction(G){
      const roll = Math.random();
      if(roll < 2/3){
        G.card.value += 10;
        addLog(`😴 怠惰惡魔：放棄選擇，資源+10！現在 ${G.card.value}`,'g');
      } else {
        G.card.value = 1;
        addLog(`😴 怠惰惡魔：放棄選擇，資源變成1！`,'b');
      }
      updateCard(G.card);
    }
  },
  lust: {
    id:'lust', name:'慾望惡魔', emoji:'💘', isDemon:true,
    pos:'僅經過2個設施時，輸出×2',
    neg:'經過2個以上設施時，資源÷設施數',
    desc:'慾望惡魔',
    modifyFinish(G, el, hitCount){
      if(hitCount === 2){
        el = {...el, value: el.value * 2};
        addLog(`💘 慾望惡魔：僅2設施，輸出×2！→ ${el.value}`,'g');
      } else if(hitCount > 2){
        el = {...el, value: Math.max(1, Math.floor(el.value / hitCount))};
        addLog(`💘 慾望惡魔：${hitCount}設施，資源÷${hitCount} → ${el.value}`,'b');
      }
      return el;
    }
  },
  wrath: {
    id:'wrath', name:'激情惡魔', emoji:'🔥', isDemon:true,
    pos:'減少效果被逆轉為增加',
    neg:'超過5回合未遇減少效果，收益減33%',
    desc:'激情惡魔',
    state:{ noDebuffTurns:0 },
    onTurnEnd(G, hadDebuff){
      const st = G.partnerState.wrath || { noDebuffTurns:0 };
      if(hadDebuff){ st.noDebuffTurns=0; }
      else { st.noDebuffTurns++; }
      if(st.noDebuffTurns > 5){
        const cut = Math.floor(G.profit * 0.33);
        G.profit = Math.max(0, G.profit - cut);
        addLog(`🔥 激情惡魔：超過5回合無減益，收益-33%`,'b');
      }
      G.partnerState.wrath = st;
    }
  },
  envy: {
    id:'envy', name:'嫉妒惡魔', emoji:'💚', isDemon:true,
    pos:'獲得嫉妒工廠（金錢→1鑽石；鑽石過商店×12）',
    neg:'非鑽石進入嫉妒工廠時，最終收益-50%',
    desc:'嫉妒惡魔',
  },
  greed: {
    id:'greed', name:'貪婪惡魔', emoji:'💰', isDemon:true,
    pos:'每回合結束額外獲得本回合收益50%',
    neg:'每輪開始目標+50%',
    desc:'貪婪惡魔',
    onRoundStart(G){
      G.goal = Math.ceil(G.goal * 1.5);
