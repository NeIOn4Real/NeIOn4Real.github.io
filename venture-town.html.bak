    onTurnEnd(G, turnProfit){
      const bonus = Math.floor(turnProfit * 0.5);
      if(bonus > 0){
        G.profit += bonus;
        addLog(`💰 貪婪惡魔：回合收益+50% → +${bonus}`,'g');
        setTimeout(()=>profitFlyFromPartner('greed',bonus),200);
      }
    }
  },
