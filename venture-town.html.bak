const EVENTS=[
  {
    id:'pick_fac', title:'🏗 設施補給', onShow:()=>tryDialogue('event_設施補給'), desc:'從以下設施選一個加入手牌：',
    show:(ev)=>{
      // 大地主負面：必須先失去一個設施
      if(hasPartner('landlord')){
        const allFac=[];
        for(let r=0;r<GN();r++) for(let cc=0;cc<GN();cc++) if(G.grid[r][cc]) allFac.push({r,cc});
        const handFac=G.hand.filter(h=>h.count>0);
        if(allFac.length>0||handFac.length>0){
          addLog('🏗 大地主：設施補給觸發，必須失去一個設施','b');
          G._landlordPenaltyPending=true;
        }
      }
      const pool=Object.keys(BLDG).filter(id=>id!=='envy_factory').sort(()=>Math.random()-.5).slice(0,3);
      showCardChooser(
        '🏗 設施補給',
        pool.map(id=>({
          emoji:BLDG[id].emoji, name:BLDG[id].name,
          desc:BLDG[id].desc, pos:'', neg:'',
          onclick:`cardChooserPick(()=>{evPick('${id}',null)})`
        })),
        ()=>evDone()
      );
    },
  },
  {
    id:'mat_boom', title:'📈 原料出口熱', onShow:()=>tryDialogue('event_原料出口熱'), desc:'本回合：原料轉換其他單位效果 ×2',
    show:(ev)=>{ showEv(ev.title,ev.desc,`<button class="eopt pri" onclick="applyBuff('matOutMult',2)">確認</button>`); },
  },
  {
    id:'goods_up', title:'🛒 商品熱銷', onShow:()=>tryDialogue('event_商品熱銷'), desc:'本回合：商品→金錢額外 +2',
    show:(ev)=>{ showEv(ev.title,ev.desc,`<button class="eopt pri" onclick="applyBuff('goodsBonus',2)">確認</button>`); },
  },

  {
    id:'typhoon', title:'🌀 颱風來襲', onShow:()=>tryDialogue('event_颱風來襲'), desc:'只能從隨機一個方向投入，物流中心失效，原料→金錢翻倍',
    show:(ev)=>{
      const dirs=['left','right','top','bottom'];
      const labels={left:'← 左側',right:'→ 右側',top:'↑ 上方',bottom:'↓ 下方'};
      const d=dirs[Math.floor(Math.random()*4)];
      G.windDir=d;
      G.buff.typhoonActive=true; // disables logistics
      G.buff.matToMoneyDouble=true;
      showEv(ev.title,`颱風！只能從 ${labels[d]} 投入，物流中心失效，原料→金錢翻倍`,`<button class="eopt pri" onclick="evDone()">確認</button>`);
    },
  },
  {
    id:'rebellion', title:'⚔ 地區叛亂', onShow:()=>tryDialogue('event_地區叛亂'), desc:'隨機消滅1-4個角落的設施',
    show:(ev)=>{
      const n=GN(); const corners=[[0,0],[0,n-1],[n-1,0],[n-1,n-1]].filter(([r,cc])=>G.grid[r][cc]);
      const count=Math.min(corners.length,Math.floor(Math.random()*4)+1);
      const victims=corners.sort(()=>Math.random()-.5).slice(0,count);
      victims.forEach(([r,cc])=>{
        const bId=G.grid[r][cc];
        if(bId){
          addLog(`⚔ 地區叛亂：${BLDG[bId].emoji}${BLDG[bId].name} (${r+1},${cc+1}) 被消滅！`,'b');
          destroyFacility(r,cc);
        }
      });
      if(victims.length===0) addLog('⚔ 地區叛亂：角落無設施，安然無恙');
      showEv(ev.title,`消滅了 ${victims.length} 個角落設施`,`<button class="eopt pri" onclick="evDone()">確認</button>`);
    },
  },
  {
    id:'skip', _dialogueKey:'event_平靜的一天', title:'😴 平靜的一天', onShow:()=>tryDialogue('event_平靜的一天'), desc:'什麼都沒發生。',
    show:(ev)=>{ showEv(ev.title,ev.desc,`<button class="eopt pri" onclick="evDone()">繼續</button>`); },
  },
  {
    id:'row_buff', title:'📈 行業熱潮', desc:'隨機一行設施本輪互動額外 +1，另一行 -1',
    show:(ev)=>{
      const r1=Math.floor(Math.random()*N), r2=(r1+1+Math.floor(Math.random()*(N-1)))%N;
      applyRowColMod('row',r1,1); applyRowColMod('row',r2,-1);
      showEv(ev.title,`第${r1+1}行 +1 互動值，第${r2+1}行 -1 互動值（本輪有效）`,`<button class="eopt pri" onclick="evDone()">確認</button>`);
    },
  },
  {
    id:'col_buff', title:'📊 區域效應', onShow:()=>tryDialogue('event_區域效應'), desc:'隨機一列設施本輪互動額外 +1，另一列 -1',
    show:(ev)=>{
      const c1=Math.floor(Math.random()*N), c2=(c1+1+Math.floor(Math.random()*(N-1)))%N;
      applyRowColMod('col',c1,1); applyRowColMod('col',c2,-1);
      showEv(ev.title,`第${c1+1}列 +1 互動值，第${c2+1}列 -1 互動值（本輪有效）`,`<button class="eopt pri" onclick="evDone()">確認</button>`);
    },
  },
  {
    id:'area_buff', title:'🌀 地塊共鳴', desc:'隨機2×2區域增益+1，另一區域-1',
    show:(ev)=>{
      const r1=Math.floor(Math.random()*(N-1)), c1=Math.floor(Math.random()*(N-1));
      let r2,c2;
      do{ r2=Math.floor(Math.random()*(N-1)); c2=Math.floor(Math.random()*(N-1)); }while(r2===r1&&c2===c1);
      apply2x2Mod(r1,c1,1); apply2x2Mod(r2,c2,-1);
      showEv(ev.title,`(${r1+1},${c1+1})區域+1，(${r2+1},${c2+1})區域-1（本輪有效）`,`<button class="eopt pri" onclick="evDone()">確認</button>`);
    },
  },
];

function applyRowColMod(axis,idx,val){
  for(let i=0;i<N;i++){
    const key=axis==='row'?`${idx},${i}`:`${i},${idx}`;
    G.cellMods[key]=(G.cellMods[key]||0)+val;
  }
  flashModCells(axis,idx,val);
}
function apply2x2Mod(r,c,val){
  for(let dr=0;dr<2;dr++) for(let dc=0;dc<2;dc++){
    const key=`${r+dr},${c+dc}`;
    G.cellMods[key]=(G.cellMods[key]||0)+val;
  }
  flash2x2Cells(r,c,val);
}
function flashModCells(axis,idx,val){
  setTimeout(()=>{
    for(let i=0;i<N;i++){
      const [r,ci]=axis==='row'?[idx,i]:[i,idx];
      const el=document.querySelector(`[data-r="${r}"][data-c="${ci}"]`);
      if(el){ el.style.outline=`3px solid ${val>0?'var(--green)':'var(--red)'}`;
        setTimeout(()=>el.style.outline='',1200); }
    }
  },100);
}
function flash2x2Cells(r,c,val){
  setTimeout(()=>{
    for(let dr=0;dr<2;dr++) for(let dc=0;dc<2;dc++){
      const el=document.querySelector(`[data-r="${r+dr}"][data-c="${c+dc}"]`);
      if(el){ el.style.outline=`3px solid ${val>0?'var(--green)':'var(--red)'}`;
        setTimeout(()=>el.style.outline='',1200); }
    }
  },100);
}

