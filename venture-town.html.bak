// 狀態
// ══════════════════════════════════════
const EVENT_TURNS=[5,10];
const EVENT_INTERVAL=3; // 每 3 回合一次（第 3、6、9 回合）

let G;
function newGame(){
  return {
    round:1,
    turn:1, maxTurns:10,
    goal:30, profit:0,
    card:{ value:1, type:'money' },  // 卡牌狀態，跨回合保留
    grid:Array(N).fill(null).map(()=>Array(N).fill(null)),
    hand:[
      {id:'mat_factory',count:2},
      {id:'factory',count:2},
      {id:'shop',count:2},
    ],
    sel:null,
    phase:'place',
    buff:{},
    nextEvent:null,      // 預告的隨機事件
    nextEventTurn:3,     // 預告事件將在哪個回合觸發
    actionOptions:[],    // 本回合2個行動選項
    moveMode:false,      // 移動設施模式
    moveSrc:null,
    upgradeMode:false,   // 提升設施模式
    freeRearrange:false, // 自由重新排列設施模式
    demolitionCharges:0,  // 拆遷隊可用次數
    partnerPool:[],      // 合夥人招募池（含未選起始合夥人）
    _tanyaNewBldg:{},    // 譚雅加成待套用
    gridSize:4,           // 地圖大小（大地主可擴到5）
    windDir:null,         // 場風大師本回合指定方向
    talentCards:0,        // 人材數量
    elementExtraUses:0,   // 元素卡本回合剩餘額外投入次數
    bldgUpgrades:{},      // 格子升級加成 {'r,c': bonus}
    cellOverlay:{},      // 物流之王疊加設施 {'r,c': bldgId}
    ruinCells:new Set(), // 廢墟格子
    futuresLock:{},     // 期貨交易所鎖定倍率
    bombTimers:{},      // 爆破裝置倒數計時
    exchangeRates:{},   // (legacy)
    _exchangeBoardActive:false, // 匯率波動板本次投入觸發標記
    logisticsVault:{},  // 物流倉儲存值
    talentBankStored:0, // 人力銀行儲存值
    tempShedMoves:{},   // 臨時工棚移動次數
    partners:[],         // 當前持有的合夥人 [{id, state}]
    partnerState:{},     // 合夥人專屬狀態 {id: any}
    turnFacilitiesHit:0, // 本次投入經過的設施數
    turnBuildingTypes:[], // 本次投入經過的設施類型
    nextBonus:null,      // 下次輸出特定單位加成 {type, amount}
    cellMods:{},         // 格子修正值 {"r,c": +1/-1}，永久到下輪
    logs:[],
    turnLog:[],         // 本回合 log
    turnLogHistory:[]   // 最近3回合 log
  };
}

function startRound(){
  G.cellMods={};
  pickNextEvent();
  pickActionOptions();
  // partner round start effects
  G.partners.forEach(pid=>{
    const p=PARTNERS[pid];
    if(p&&p.onRoundStart) p.onRoundStart(G);
  });
  // 稅務局：每回合開始隨機升級一個設施
  {
    let taxCells=[];
    for(let r=0;r<GN();r++) for(let cc=0;cc<GN();cc++) if(G.grid[r][cc]==='tax_office') taxCells.push([r,cc]);
    if(taxCells.length>0){
      const allFilled=[];
      for(let r=0;r<GN();r++) for(let cc=0;cc<GN();cc++) if(G.grid[r][cc]&&G.grid[r][cc]!=='tax_office') allFilled.push([r,cc]);
      if(allFilled.length>0){
        const [tr,tc]=allFilled[Math.floor(Math.random()*allFilled.length)];
        const key=`${tr},${tc}`;
        G.bldgUpgrades[key]=(G.bldgUpgrades[key]||0)+1;
        addLog(`🏛 稅務局：${BLDG[G.grid[tr][tc]].emoji}${BLDG[G.grid[tr][tc]].name} (${tr+1},${tc+1}) 自動升級！`,'w');
      }
    }
  }
  addLog(`══ 第 ${G.round} 輪　目標收益：${G.goal} ══`,'w');
  // 合夥人第一回合開始效果
  G.partners.forEach(pid=>{
    const p=PARTNERS[pid];
    if(p&&p.onTurnStart) p.onTurnStart(G);
  });
  // 場風大師：第一回合抽方向
  if(hasPartner('wind_master')){
    const dirs=['left','right','top','bottom'];
    const labels={left:'← 左側',right:'→ 右側',top:'↑ 上方',bottom:'↓ 下方'};
    G.windDir=dirs[Math.floor(Math.random()*dirs.length)];
    addLog(`🌀 場風大師：本回合只能從 ${labels[G.windDir]} 投入，獲得×2倍率`,'w');
  } else {
    G.windDir=null;
  }
  G.phase='place';
  render();
  if(hasPartner('tanya')){
    tanyaOfferSwap();
  } else {
    openActionOverlay();
  }
}

function addLog(msg,cls=''){
  // Add to current turn log entries
  if(!G.turnLog) G.turnLog=[];
  G.turnLog.push({msg,cls});
  renderSideLog();
}

function commitTurnLog(){
  // Save current turn log to history (keep last 3 turns)
  if(!G.turnLogHistory) G.turnLogHistory=[];
  if(G.turnLog&&G.turnLog.length>0){
    G.turnLogHistory.unshift({turn:G.turn, round:G.round, entries:[...G.turnLog]});
    if(G.turnLogHistory.length>3) G.turnLogHistory.pop();
  }
  G.turnLog=[];
}
function addHand(id,n=1){
  const e=G.hand.find(h=>h.id===id);
  if(e)e.count+=n; else G.hand.push({id,count:n});
}

// ══════════════════════════════════════
// 事件
// ══════════════════════════════════════
function triggerEvent(){
  G.phase='event';
  const ev=EVENTS[Math.floor(Math.random()*EVENTS.length)];
  ev.show(ev);
  render();
}
function showEv(title,desc,optsHtml){
  document.getElementById('ev-title').textContent=title;
  document.getElementById('ev-desc').textContent=desc;
  document.getElementById('ev-opts').innerHTML=optsHtml;
  document.getElementById('ev-banner').classList.add('show');
  DM.onEvent(title);
}
function hideEv(){
  document.getElementById('ev-banner').classList.remove('show');
}
function evDone(){
  hideEv();
  // 拆遷隊：每3回合事件後可免費重排
  if(hasPartner('demolition') && G.turn % 3 === 0){
    G.demolitionCharges = (G.demolitionCharges||0) + 1;
    addLog('🔨 拆遷隊：本回合為第'+G.turn+'回合（3的倍數），獲得免費重排機會！','g');
    renderPartners();
  }
  G.actionOptions=[];
  pickActionOptions();
  G.phase='place';
  addLog(`── 回合 ${G.turn}/${G.maxTurns} ──`);
  render();
}
function evPickTanya(id, tanyaBonus){
  // 選設施後加入手牌，若譚雅效果則額外+1升級
  addHand(id);
  if(tanyaBonus){
    // 找到手牌中此設施並記錄+1升級標記（作為初始升級加成）
    G._tanyaNewBldg = G._tanyaNewBldg || {};
    G._tanyaNewBldg[id] = (G._tanyaNewBldg[id]||0) + 1;
    addLog(`👩‍💼 譚雅：${BLDG[id].emoji}${BLDG[id].name} 加入手牌，額外 +1！`,'g');
  } else {
    addLog(`🎁 獲得 ${BLDG[id].emoji}${BLDG[id].name}！`,'g');
  }
  evDone();
}

function evPick(id,fromEl){
  addHand(id);
  addLog(`🎁 獲得 ${BLDG[id].emoji}${BLDG[id].name}！`,'g');
  if(fromEl){
    const src=fromEl.getBoundingClientRect();
    const dst=document.getElementById('hand-list').getBoundingClientRect();
    const fly=document.createElement('div');
    fly.textContent=BLDG[id].emoji;
    fly.style.cssText=`position:fixed;left:${src.left+src.width/2}px;top:${src.top+src.height/2}px;
      font-size:28px;pointer-events:none;z-index:500;transition:all .6s cubic-bezier(.4,0,.2,1);`;
    document.body.appendChild(fly);
    setTimeout(()=>{
      fly.style.left=(dst.left+20)+'px';
      fly.style.top=(dst.top+10)+'px';
      fly.style.opacity='0';fly.style.fontSize='14px';
    },30);
    setTimeout(()=>fly.remove(),700);
  }
  hideEv();
  closeCardChooser();
  closeActionOverlay();
  G.actionOptions=[];
  startTurn();
}
function applyBuff(key,val){
  G.buff[key]=val;
  const msgs={matOutMult:'📈 本回合原料輸出 ×2',goodsBonus:'🛒 本回合商品→金錢 +2'};
  addLog(msgs[key]||'效果已套用','w');
  evDone();
}

// ══════════════════════════════════════
// 放設施
// ══════════════════════════════════════
function selBldg(id){
  if(G.phase!=='place')return;
  G.sel=G.sel===id?null:id;
  if(G.sel&&BLDG[G.sel]&&BLDG[G.sel].ruinOnly){
    const count=G.ruinCells?G.ruinCells.size:0;
    if(count===0) addLog('🗿 目前沒有廢墟格可放置','b');
    else addLog(`🗿 請點擊廢墟格（灰色斜紋格子）放置，共${count}個`,'w');
  }
  render();
  renderFanHand();
}
function onCell(r,c){
  if(G.phase!=='place')return;

  // 提升設施模式
  if(G.upgradeMode){
    if(!G.grid[r][c]){addLog('請點擊有設施的格子','b');return;}
    upgradeCell(r,c);
    return;
  }

  // 自由排列模式（點擊交換格子）
  if(G.freeRearrange){
    if(!G.moveSrc){
      if(!G.grid[r][c]){addLog('請先點擊要移動的設施格子','b');return;}
      G.moveSrc=[r,c];
      addLog(`選中 ${BLDG[G.grid[r][c]].emoji}${BLDG[G.grid[r][c]].name}，點目標格子（空格或另一設施）`);
      render(); return;
    } else {
      const [sr,sc]=G.moveSrc;
      if(r===sr&&c===sc){G.moveSrc=null;render();return;}
      // swap (can swap two buildings or move to empty)
      const tmp=G.grid[r][c];
      G.grid[r][c]=G.grid[sr][sc];
      G.grid[sr][sc]=tmp;
      // transfer bldgUpgrades with the building
      const ku=`${sr},${sc}`, kv=`${r},${c}`;
      if(G.bldgUpgrades){
        const tmp2=G.bldgUpgrades[ku];
        G.bldgUpgrades[ku]=G.bldgUpgrades[kv];
        G.bldgUpgrades[kv]=tmp2;
        if(!G.bldgUpgrades[ku]) delete G.bldgUpgrades[ku];
        if(!G.bldgUpgrades[kv]) delete G.bldgUpgrades[kv];
      }
      addLog(`🔧 已交換 (${sr+1},${sc+1}) ↔ (${r+1},${c+1})`,'g');
      G._facilitiesMovedThisTurn=(G._facilitiesMovedThisTurn||0)+1;
      // 臨時工棚：移動次數累計
      if(!G.tempShedMoves) G.tempShedMoves={};
      for(let ri=0;ri<GN();ri++) for(let ci=0;ci<GN();ci++){
        if(G.grid[ri][ci]==='temp_shed'){
          const tk=`${ri},${ci}`;
          G.tempShedMoves[tk]=Math.min((G.tempShedMoves[tk]||0)+1,5);
        }
      }
      // 拆遷補償局：+1收益
      if(hasPartner('facility_destroyer')||G.hand.some(h=>h.id==='demolish_bureau'&&h.count>0)||[].concat(...G.grid).includes('demolish_bureau')){ let f=false; for(let ri=0;ri<GN();ri++) for(let ci=0;ci<GN();ci++) if(G.grid[ri][ci]==='demolish_bureau') f=true; if(f){G.profit+=1;addLog('🏢 拆遷補償局：設施移動+1收益','g');} }
      G.moveSrc=null;
      pulse(r,c);render(); return;
    }
  }

  // 一般移動設施模式
  if(G.moveMode){
    if(!G.moveSrc){
      if(!G.grid[r][c]){addLog('請點擊有設施的格子','b');return;}
      G.moveSrc=[r,c];
      addLog(`選中 ${BLDG[G.grid[r][c]].emoji}${BLDG[G.grid[r][c]].name}，再點空格放置`);
      render(); return;
    } else {
      const [sr,sc]=G.moveSrc;
      if(r===sr&&c===sc){G.moveSrc=null;render();return;}
      if(G.grid[r][c]){addLog('目標格子已有設施','b');return;}
      G.grid[r][c]=G.grid[sr][sc];
      G.grid[sr][sc]=null;
      addLog(`移動 ${BLDG[G.grid[r][c]].emoji}${BLDG[G.grid[r][c]].name} 到 (${r+1},${c+1})`,'g');
      G.moveMode=false;G.moveSrc=null;
      pulse(r,c);render(); return;
    }
  }

  // 正常放置模式
  if(!G.sel){addLog('請先選擇手牌設施','b');return;}
  // 廢墟紀念碑：只能放在廢墟格
  if(G.sel&&BLDG[G.sel]&&BLDG[G.sel].ruinOnly){
    if(!(G.ruinCells&&G.ruinCells.has(`${r},${c}`))){
      const ruinList=G.ruinCells&&G.ruinCells.size>0
        ?[...G.ruinCells].map(k=>`(${parseInt(k)+1},${parseInt(k.split(',')[1])+1})`).join(' ')
        :'無廢墟格';
      addLog(`🗿 廢墟紀念碑只能放在廢墟格！目前廢墟：${[...( G.ruinCells||[])].map(k=>{const[rr,cc]=k.split(',');return `(${+rr+1},${+cc+1})`;}).join(' ')||'無'}`,'b');
      return;
    }
  }
  // 蕾雅：相同設施點擊同類設施格 → 視為升級
  if(G.sel&&G.grid[r][c]&&G.grid[r][c]===G.sel&&hasPartner('leya')){
    const e2=G.hand.find(h=>h.id===G.sel);
    if(!e2||e2.count<=0){ addLog('👩‍🔧 蕾雅：手牌不足','b'); return; }
    e2.count--;
    const key=`${r},${c}`;
    G.bldgUpgrades[key]=(G.bldgUpgrades[key]||0)+1;
    addLog(`👩‍🔧 蕾雅：${BLDG[G.sel].emoji}${BLDG[G.sel].name} (${r+1},${c+1}) 升級！現在 +${G.bldgUpgrades[key]}`,'g');
    G.sel=null; pulse(r,c); render(); return;
  }
  // 中央限定設施
  if(G.sel&&BLDG[G.sel]&&BLDG[G.sel].centerOnly&&!isCenterCell(r,c)){
    addLog(`🚫 ${BLDG[G.sel].name}只能放在中央區域！`,'b');
    return;
  }
  // 物流之王：允許疊在物流中心上
  if(G.grid[r][c]){
    const existing=BLDG[G.grid[r][c]];
    if(existing&&existing.special==='redirect'&&hasPartner('logistics_king')&&!G.cellOverlay[`${r},${c}`]){
      const e2=G.hand.find(h=>h.id===G.sel);
      if(!e2||e2.count<=0) return;
      e2.count--;
      G.cellOverlay[`${r},${c}`]=G.sel;
      addLog(`🚛 物流之王：${BLDG[G.sel].emoji}${BLDG[G.sel].name} 疊加在 ${existing.emoji}${existing.name} 上！`,'g');
      G.sel=null; pulse(r,c); render(); return;
    }
    addLog('該格子已有設施','b');return;
  }
  const e=G.hand.find(h=>h.id===G.sel);
  if(!e||e.count<=0)return;
  e.count--;
  G.grid[r][c]=G.sel;
  addLog(`放置 ${BLDG[G.sel].emoji}${BLDG[G.sel].name} (${r+1},${c+1})`);
  G.sel=null;
  pulse(r,c);
  render();
}

// ══════════════════════════════════════
// 送入元素
// ══════════════════════════════════════
// ══════════════════════════════════════
// 元素卡牌拖曳系統
// ══════════════════════════════════════
let cardDragging=false;

function onCardDragStart(e){
  if(G.phase!=='place'){e.preventDefault();return;}
  cardDragging=true;
  e.dataTransfer.effectAllowed='move';
  e.dataTransfer.setData('text/plain','el-card');
  document.body.classList.add('card-dragging');
}
function onCardDragEnd(e){
  cardDragging=false;
  document.body.classList.remove('card-dragging');
  document.querySelectorAll('.dbtn').forEach(b=>b.classList.remove('drag-over'));
}
function onDirDragOver(e,btn){
  if(!cardDragging)return;
  e.preventDefault();
  e.dataTransfer.dropEffect='move';
  btn.classList.add('drag-over');
}
function onDirDragLeave(btn){btn.classList.remove('drag-over');}
function onDirDrop(e,dir,idx){
  e.preventDefault();
  document.body.classList.remove('card-dragging');
  document.querySelectorAll('.dbtn').forEach(b=>b.classList.remove('drag-over'));
  if(!cardDragging)return;
  cardDragging=false;
  sendEl(dir,idx);
}

// 設施拖曳到格子
let bldgDragging=null;
function onBldgDragStart(e,id){
  if(G.phase!=='place'){e.preventDefault();return;}
  const h=G.hand.find(h=>h.id===id);
  if(!h||h.count<=0){e.preventDefault();return;}
  bldgDragging=id;
  e.dataTransfer.effectAllowed='move';
  e.dataTransfer.setData('text/plain','bldg:'+id);
  // 高亮空格子
  document.querySelectorAll('.cell:not(.filled)').forEach(c=>c.classList.add('drag-target'));
}
function onBldgDragEnd(e){
  bldgDragging=null;
  document.querySelectorAll('.cell').forEach(c=>{c.classList.remove('drag-target');c.classList.remove('drag-over-cell');});
}
function onCellDragOver(e,r,c){
  if(!bldgDragging) return;
  // 蕾雅：允許拖到相同設施的格子
  const isLeyaUpgrade = G.grid[r][c]===bldgDragging && hasPartner('leya');
  if(G.grid[r][c] && !isLeyaUpgrade) return;
  e.preventDefault();
  const cellEl=document.querySelector(`[data-r="${r}"][data-c="${c}"]`);
  cellEl?.classList.add('drag-over-cell');
  if(isLeyaUpgrade && cellEl){
    cellEl.style.outline='3px solid var(--money)';
    cellEl.style.boxShadow='0 0 12px rgba(176,96,0,.45)';
  }
}
function onCellDragLeave(r,c){
  const cellEl=document.querySelector(`[data-r="${r}"][data-c="${c}"]`);
  cellEl?.classList.remove('drag-over-cell');
  if(cellEl){ cellEl.style.outline=''; cellEl.style.boxShadow=''; }
}
function onCellDrop(e,r,c){
  e.preventDefault();
  document.querySelectorAll('.cell').forEach(c=>{c.classList.remove('drag-target');c.classList.remove('drag-over-cell');});
  if(!bldgDragging) return;

  // 蕾雅：相同設施拖到小鎮格子 → 視為升級
  if(G.grid[r][c]===bldgDragging && hasPartner('leya')){
    const h=G.hand.find(h=>h.id===bldgDragging);
    if(!h||h.count<=0){ addLog('👩‍🔧 蕾雅：手牌不足','b'); bldgDragging=null; return; }
    h.count--;
    const key=`${r},${c}`;
    G.bldgUpgrades[key]=(G.bldgUpgrades[key]||0)+1;
    addLog(`👩‍🔧 蕾雅：${BLDG[bldgDragging].emoji}${BLDG[bldgDragging].name} (${r+1},${c+1}) 升級！現在 +${G.bldgUpgrades[key]}`,'g');
    bldgDragging=null;
    pulse(r,c); render(); return;
  }

  if(G.grid[r][c]) return; // 格子已有設施（且非蕾雅升級）
  const h=G.hand.find(h=>h.id===bldgDragging);
  if(!h||h.count<=0) return;
  h.count--;
  G.grid[r][c]=bldgDragging;
  // Tutorial hook
  if(TUT.active){
    if(TUT.waitingFor==='place_mat_factory' && bldgDragging==='mat_factory') TUT.onAction('place_mat_factory');
    else if(TUT.waitingFor==='place_factory_shop' && (bldgDragging==='factory'||bldgDragging==='shop')){
      // check if both placed
      let hasFac=false,hasShop=false;
      for(let ri=0;ri<GN();ri++) for(let ci=0;ci<GN();ci++){
        if(G.grid[ri][ci]==='factory') hasFac=true;
        if(G.grid[ri][ci]==='shop') hasShop=true;
      }
      if(hasFac&&hasShop) TUT.onAction('place_factory_shop');
    }
  }
  // 譚雅：放置時套用額外+1升級
  if(G._tanyaNewBldg && G._tanyaNewBldg[bldgDragging] > 0){
    const key=`${r},${c}`;
    G.bldgUpgrades[key]=(G.bldgUpgrades[key]||0)+1;
    G._tanyaNewBldg[bldgDragging]--;
    if(G._tanyaNewBldg[bldgDragging]<=0) delete G._tanyaNewBldg[bldgDragging];
    addLog(`放置 ${BLDG[bldgDragging].emoji}${BLDG[bldgDragging].name} (${r+1},${c+1})（譚雅+1已套用）`);
  } else {
    addLog(`放置 ${BLDG[bldgDragging].emoji}${BLDG[bldgDragging].name} (${r+1},${c+1})`);
  }
  bldgDragging=null;
  pulse(r,c);
  render();
}

// ══════════════════════════════════════
// 更新元素卡牌 UI
// ══════════════════════════════════════
function updateCard(el){
  G.card=el;
  if(typeof renderFanHand==='function') renderFanHand();
  if(typeof renderTalentPanel==='function') renderTalentPanel();
}


// ══════════════════════════════════════
// 元素投入主流程
// ══════════════════════════════════════
function sendEl(dir,idx){
  if(G.phase!=='place')return;
  // 颱風：只能從指定方向投入
  if(G.buff&&G.buff.typhoonActive&&G.windDir&&dir!==G.windDir){
    addLog(`🌀 颱風：只能從 ${G.windDir} 方向投入！`,'b');
    return;
  }
  // 場風大師：只能從指定方向投入
  if(hasPartner('wind_master')){
    const wd=getWindDir();
    if(wd && dir!==wd){
      addLog(`🌀 場風大師：本回合只能從 ${wd} 方向投入！`,'b');
      return;
    }
  }
  G.phase='animating';
  G._tutHitMatFactory = false; // 教學：每次投入重置
  G.sel=null;
  render();

  const path=[];
  const _N=GN();
  if(dir==='left')  for(let c=0;c<_N;c++)     path.push([idx,c]);
  if(dir==='right') for(let c=_N-1;c>=0;c--) path.push([idx,c]);
  if(dir==='top')   for(let r=0;r<_N;r++)     path.push([r,idx]);
  if(dir==='bottom')for(let r=_N-1;r>=0;r--)  path.push([r,idx]);

  let startCard = {...G.card};
  // Gluttony: swap material/goods
  if(hasPartner('gluttony') && !isDemonNegDisabled()){
    if(startCard.type==='material') startCard={...startCard,type:'goods'};
    else if(startCard.type==='goods') startCard={...startCard,type:'material'};
  }
  G.turnFacilitiesHit=0;
  G._triggeredLogistics=new Set();
  G._envyPenalty=false;
  G._centerHits=0;
  G._logisticsHitThisTurn=0;
  G._facilitiesMovedThisTurn=0;
  G._windCorrect=hasPartner('wind_master')&&!!G.windDir; // set true; will be validated at send
  const startVal=startCard.value;
  const startType=startCard.type;
  let el={value:startVal,type:startType};
  const dname={left:'左側',right:'右側',top:'上方',bottom:'下方'}[dir];
  addLog(`▶ 送入 ${TLABEL[startType]} ${startVal}`,'h');
  updateCard(el);

  // 啟動移動器
  const mover=document.getElementById('el-mover');
  mover.style.display='flex';
  const emojis={money:'💵',material:'🪨',goods:'📦'};
  function updateMover(el){
    mover.querySelector('.mv-emoji').textContent=emojis[el.type]||'❓';
    mover.querySelector('.mv-val').textContent=el.value;
    mover.querySelector('.mv-val').style.color=TCOLOR[el.type]||'var(--tx)';
    mover.querySelector('.mv-type').textContent=TLABEL[el.type]||el.type;
    mover.style.borderColor=TCOLOR[el.type]||'var(--acc)';
  }
  updateMover(el);

  stepWithMover(path,el,0,startVal,mover,updateMover);
}

function stepWithMover(path,el,i,startVal,mover,updateMover){
  if(i>=path.length){
    mover.style.display='none';
    finish(el,startVal);
    return;
  }
  const[r,c]=path[i];

  // 移動移動器到格子位置
  const cellEl=document.querySelector(`[data-r="${r}"][data-c="${c}"]`);
  if(cellEl){
    const rect=cellEl.getBoundingClientRect();
    mover.style.left=(rect.left+2)+'px';
    mover.style.top=(rect.top+2)+'px';
  }

  // 高亮當前格
  document.querySelectorAll('.cell').forEach(c=>c.classList.remove('active-path'));
  cellEl?.classList.add('active-path');

  const bId=G.grid[r][c];
  if(bId){
    const b=BLDG[bId];
    // 教學：記錄是否通過原料廠
    if(TUT.active && bId==='mat_factory') G._tutHitMatFactory = true;

    // ── 人材幣通過商店：×3 變金錢 ──
    if(el.type==='talent_coin' && bId==='shop'){
      G.turnFacilitiesHit=(G.turnFacilitiesHit||0)+1;
      const nv2=el.value*3+(G.bldgUpgrades&&G.bldgUpgrades[`${r},${c}`]||0);
      addLog(`  🏪 商店: 人材幣${el.value}→💰${nv2}（×3）`,'g');
      el={value:nv2,type:'money'};
      pulse(r,c); updateCard(el);
      setTimeout(()=>{ updateMover(el); setTimeout(()=>stepWithMover(path,el,i+1,startVal,mover,updateMover),350); },350);
      return;
    }
    // ── 鑽石通過商店：×12 變金錢 ──
    if(el.type==='diamond' && bId==='shop'){
      G.turnFacilitiesHit=(G.turnFacilitiesHit||0)+1;
      const prev={...el};
      let nv=el.value*12+(G.bldgUpgrades&&G.bldgUpgrades[`${r},${c}`]||0);
      el={value:nv,type:'money'};
      pulse(r,c);
      cellEl?.classList.add('transform-flash');
      setTimeout(()=>cellEl?.classList.remove('transform-flash'),500);
      if(cellEl){
        const badge=document.createElement('div');
        badge.className='change-badge';
        badge.textContent=`💚 ${BLDG.shop.emoji}商店: 💎${prev.value} → 💰${nv} (×12)`;
        badge.style.background=TCOLOR.money;
        cellEl.appendChild(badge);
        setTimeout(()=>badge.remove(),800);
      }
      addLog(`  🏪 商店: 💎鑽石 ${prev.value} → 💰金錢 ${nv} (×12)`,'g');
      // partner onBuildingHit
      G.partners.forEach(pid=>{ const p=PARTNERS[pid]; if(p&&p.onBuildingHit){ const pb=G.profit; p.onBuildingHit(G,'shop'); const g=G.profit-pb; if(g>0){addLog(`  ${p.emoji}${p.name}：+${g} 收益`,'g');setTimeout(()=>profitFlyFromPartner(pid,g),200);} } });
      updateCard(el);
      setTimeout(()=>{ updateMover(el); setTimeout(()=>stepWithMover(path,el,i+1,startVal,mover,updateMover),350); },350);
      return;
    }

    // ── 貿易代理：金錢→1%原料；商品→1%金錢（中央限定）──
    if(b.special==='trade_hub'){
      if(el.type==='money'){
        const add=Math.max(1,Math.floor(el.value*0.01));
        const nv2=el.value+add;
        addLog(`  🌐 貿易代理：💰金錢${el.value} → 🪨原料${nv2} (+${add}, +1%)`);
        el={value:nv2,type:'material'};
      } else if(el.type==='goods'){
        const add=Math.max(1,Math.floor(el.value*0.01));
        const nv2=el.value+add;
        addLog(`  🌐 貿易代理：📦商品${el.value} → 💰金錢${nv2} (+${add}, +1%)`);
        el={value:nv2,type:'money'};
      } else { addLog(`  🌐 貿易代理：類型不符，略過`); }
      G.turnFacilitiesHit=(G.turnFacilitiesHit||0)+1;
      pulse(r,c); updateCard(el);
      setTimeout(()=>stepWithMover(path,el,i+1,startVal,mover,updateMover),350);
      return;
    }

    // ── 科技研發：商品→+2%商品 ──
    if(b.special==='tech_lab' && el.type==='goods'){
      const add=Math.max(1,Math.floor(el.value*0.02));
      const nv2=el.value+add;
      addLog(`  🔬 科技研發：📦商品${el.value} → 📦商品${nv2} (+${add}, +2%)`);
      el={value:nv2,type:'goods'};
      G.turnFacilitiesHit=(G.turnFacilitiesHit||0)+1;
      pulse(r,c); updateCard(el);
      setTimeout(()=>stepWithMover(path,el,i+1,startVal,mover,updateMover),350);
      return;
    }

    // ── 稅務局：資源直接通過 ──
    if(b.special==='tax_office'){
      addLog(`  🏛 稅務局：通過（最終收益-10%）`);
      G.turnFacilitiesHit=(G.turnFacilitiesHit||0)+1;
      setTimeout(()=>stepWithMover(path,el,i+1,startVal,mover,updateMover),300);
      return;
    }




    // ── 臨時工棚：每次移動+1（最高+5），通過時套用當前加成 ──
    if(b.special==='temp_shed'){
      if(!G.tempShedMoves) G.tempShedMoves={};
      const key=`${r},${c}`;
      const bonus=Math.min(G.tempShedMoves[key]||0,5);
      const nv2=applyUpgradeBonus(r,c,el.value+bonus,'臨時工棚');
      addLog(`  🛖 臨時工棚: +${bonus}（移動${G.tempShedMoves[key]||0}次）→${nv2}`);
      el={...el,value:nv2};
      G.turnFacilitiesHit=(G.turnFacilitiesHit||0)+1;
      pulse(r,c); updateCard(el);
      setTimeout(()=>stepWithMover(path,el,i+1,startVal,mover,updateMover),350);
      return;
    }

    // ── 物流放大器：通過後下一設施效果×2 ──
    if(b.special==='logistics_amp'){
      G._logisticsAmpActive=true;
      addLog(`  📡 物流放大器：下一設施效果×2`,'g');
      G.turnFacilitiesHit=(G.turnFacilitiesHit||0)+1;
      pulse(r,c); updateCard(el);
      setTimeout(()=>stepWithMover(path,el,i+1,startVal,mover,updateMover),300);
      return;
    }

    // ── 物流倉：儲存50%，下次釋放為加成 ──
    if(b.special==='logistics_vault'){
      if(!G.logisticsVault) G.logisticsVault={};
      const key=`${r},${c}`;
      const stored=G.logisticsVault[key]||0;
      const toStore=Math.floor(el.value*0.5);
      if(stored>0){
        el={...el,value:el.value+stored};
        addLog(`  🏪 物流倉：釋放儲存+${stored}→${el.value}`,'g');
        G.logisticsVault[key]=toStore;
      } else {
        G.logisticsVault[key]=toStore;
        addLog(`  🏪 物流倉：儲存${toStore}（下次釋放）`);
      }
      G.turnFacilitiesHit=(G.turnFacilitiesHit||0)+1;
      pulse(r,c); updateCard(el);
      setTimeout(()=>stepWithMover(path,el,i+1,startVal,mover,updateMover),350);
      return;
    }

    // ── 人力銀行：金錢通過儲存10%，下次投入釋放 ──
    if(b.special==='talent_bank' && el.type==='money'){
      if(!G.talentBankStored) G.talentBankStored=0;
      const stored=G.talentBankStored;
      const toStore=Math.floor(el.value*0.1);
      if(stored>0){
        el={...el,value:el.value+stored};
        addLog(`  🏧 人力銀行：釋放+${stored}→${el.value}`,'g');
        G.talentBankStored=toStore;
      } else {
        G.talentBankStored=toStore;
        addLog(`  🏧 人力銀行：儲存${toStore}（下次釋放）`);
      }
      G.turnFacilitiesHit=(G.turnFacilitiesHit||0)+1;
      pulse(r,c); updateCard(el);
      setTimeout(()=>stepWithMover(path,el,i+1,startVal,mover,updateMover),350);
      return;
    }

    // ── 集體罷工台：主動觸發消耗所有人材，各+10 ──
    // 被動通過時：若有人材則自動消耗
    if(b.special==='strike_board'){
      const talents=G.talentCards||0;
      if(talents>0){
        const bonus=talents*10;
        G.talentCards=0;
        el={...el,value:el.value+bonus};
        addLog(`  📢 集體罷工台：消耗${talents}人材，+${bonus}→${el.value}`,'g');
        renderTalentPanel();
      } else {
        addLog(`  📢 集體罷工台：無人材可消耗`);
      }
      G.turnFacilitiesHit=(G.turnFacilitiesHit||0)+1;
      pulse(r,c); updateCard(el);
      setTimeout(()=>stepWithMover(path,el,i+1,startVal,mover,updateMover),350);
      return;
    }

    // ── 人才市場：任意資源→人材幣（特殊類型，過商店×3金錢）──
    if(b.special==='talent_market'){
      addLog(`  🏦 人才市場: ${TLABEL[el.type]}→人材幣`);
      el={...el,type:'talent_coin'};
      G.turnFacilitiesHit=(G.turnFacilitiesHit||0)+1;
      pulse(r,c); updateCard(el);
      setTimeout(()=>stepWithMover(path,el,i+1,startVal,mover,updateMover),350);
      return;
    }

    // ── 進出口稅站：扣1收益，效果×2 ──
    if(b.special==='import_tax'){
      G.profit=Math.max(0,G.profit-1);
      const nv2=applyUpgradeBonus(r,c,el.value*2,'進出口稅站');
      addLog(`  🧾 進出口稅站: ×2→${nv2}（扣1收益）`);
      el={...el,value:nv2};
      G.turnFacilitiesHit=(G.turnFacilitiesHit||0)+1;
      pulse(r,c); updateCard(el);
      setTimeout(()=>stepWithMover(path,el,i+1,startVal,mover,updateMover),350);
      return;
    }

    // ── 速遞站：下一格立即再觸發 ──
    if(b.special==='speed_station'){
      addLog(`  ⚡ 速遞站：下一格將觸發兩次`);
      G._speedStationActive=true;
      G.turnFacilitiesHit=(G.turnFacilitiesHit||0)+1;
      pulse(r,c); updateCard(el);
      setTimeout(()=>stepWithMover(path,el,i+1,startVal,mover,updateMover),300);
      return;
    }

    // ── 廢墟紀念碑：輸出+5 ──
    if(b.special==='ruin_monument'){
      const nv2=applyUpgradeBonus(r,c,el.value+5,'廢墟紀念碑');
      addLog(`  🗿 廢墟紀念碑: +5→${nv2}`,'g');
      el={...el,value:nv2};
      G.turnFacilitiesHit=(G.turnFacilitiesHit||0)+1;
      pulse(r,c); updateCard(el);
      setTimeout(()=>stepWithMover(path,el,i+1,startVal,mover,updateMover),350);
      return;
    }

    // ── 期貨交易所：使用鎖定倍率 ──
    if(b.special==='futures_market' && el.type==='goods'){
      const key=`${r},${c}`;
      if(!G.futuresLock) G.futuresLock={};
      if(!G.futuresLock[key]){
        G.futuresLock[key]=Math.floor(Math.random()*3)+1;
        addLog(`  🏛 期貨交易所：鎖定倍率×${G.futuresLock[key]}（永久）`,'g');
      }
      const mult=G.futuresLock[key];
      const nv2=applyUpgradeBonus(r,c,el.value*mult,'期貨交易所');
      addLog(`  🏛 期貨交易所: 📦${el.value}→💰${nv2}（鎖定×${mult}）`,'g');
      el={value:nv2,type:'money'};
      G.turnFacilitiesHit=(G.turnFacilitiesHit||0)+1;
      pulse(r,c); updateCard(el);
      setTimeout(()=>stepWithMover(path,el,i+1,startVal,mover,updateMover),350);
      return;
    }

    // ── 拆遷補償局：資源通過並不轉換，但觸發效果 ──
    if(b.special==='demolish_bureau'){
      // 效果已在設施移動/消滅時觸發(+1收益)，此處僅允許資源通過
      G.turnFacilitiesHit=(G.turnFacilitiesHit||0)+1;
      const nv2=applyUpgradeBonus(r,c,el.value,'拆遷補償局');
      el={...el,value:nv2};
      addLog(`  🏢 拆遷補償局: 通過（移動/消滅設施時+1收益）`);
      pulse(r,c); updateCard(el);
      setTimeout(()=>stepWithMover(path,el,i+1,startVal,mover,updateMover),350);
      return;
    }

    // ── 終點站：+（已通過設施數×2）──
    if(b.special==='terminal'){
      const bonus=(G.turnFacilitiesHit||0)*2;
      G.turnFacilitiesHit=(G.turnFacilitiesHit||0)+1;
      let termVal=el.value+bonus;
      termVal=applyUpgradeBonus(r,c,termVal,'終點站');
      const t_upg=G.bldgUpgrades?.[`${r},${c}`]||0;
      const t_parts=[`通過${G.turnFacilitiesHit-1}設施×2=+${bonus}`]; if(t_upg>0) t_parts.push(`升級+${t_upg}`);
      addLog(`  🏁 終點站: ${TLABEL[el.type]}${el.value}→${termVal}（${t_parts.join('，')}）`,'g');
      el={...el,value:termVal};
      pulse(r,c); updateCard(el);
      setTimeout(()=>stepWithMover(path,el,i+1,startVal,mover,updateMover),350);
      return;
    }

    // ── 螺旋物流站：每通過1設施+2 ──
    if(b.special==='spiral_hub'){
      const bonus=(G.turnFacilitiesHit||0)*2;
      G.turnFacilitiesHit=(G.turnFacilitiesHit||0)+1;
      let spiralVal=el.value+bonus;
      spiralVal=applyUpgradeBonus(r,c,spiralVal,'螺旋物流站');
      const sp_upg=G.bldgUpgrades?.[`${r},${c}`]||0;
      const sp_parts=[`通過${G.turnFacilitiesHit-1}設施×2=+${bonus}`]; if(sp_upg>0) sp_parts.push(`升級+${sp_upg}`);
      addLog(`  🔄 螺旋物流站: +${bonus+sp_upg}（${sp_parts.join('，')}）`);
      el={...el,value:spiralVal};
      pulse(r,c); updateCard(el);
      setTimeout(()=>stepWithMover(path,el,i+1,startVal,mover,updateMover),350);
      return;
    }

    // ── 勞動轉換站：消耗2人材 → ×2 ──
    if(b.special==='labor_convert'){
      if((G.talentCards||0)>=2){
        G.talentCards-=2;
        let lc_val=el.value*2;
        lc_val=applyUpgradeBonus(r,c,lc_val,'勞動轉換站');
        el={...el,value:lc_val};
        addLog(`  ⚙️ 勞動轉換站: ×2（消耗2人材）→ ${el.value}`,'g');
      } else {
        addLog(`  ⚙️ 勞動轉換站: 人材不足（需2），略過`,'b');
      }
      G.turnFacilitiesHit=(G.turnFacilitiesHit||0)+1;
      pulse(r,c); updateCard(el);
      setTimeout(()=>stepWithMover(path,el,i+1,startVal,mover,updateMover),350);
      return;
    }

    // ── 人材倉庫：持有5+人材時+5 ──
    if(b.special==='talent_storage'){
      let ts_bonus=(G.talentCards||0)>=5?5:0;
      ts_bonus=applyUpgradeBonus(r,c,ts_bonus,'人材倉庫');
      if(ts_bonus) el={...el,value:el.value+ts_bonus};
      addLog(`  🗃️ 人材倉庫: +${ts_bonus}（人材${G.talentCards||0}個）`);
      G.turnFacilitiesHit=(G.turnFacilitiesHit||0)+1;
      pulse(r,c); updateCard(el);
      setTimeout(()=>stepWithMover(path,el,i+1,startVal,mover,updateMover),350);
      return;
    }

    // ── 派遣總部：商品通過+2人材 ──
    if(b.special==='dispatch_hq' && el.type==='goods'){
      G.talentCards=(G.talentCards||0)+2;
      addLog(`  🏢 派遣總部: +2人材（共${G.talentCards}）`,'g');
      G.turnFacilitiesHit=(G.turnFacilitiesHit||0)+1;
      pulse(r,c); updateCard(el);
      setTimeout(()=>stepWithMover(path,el,i+1,startVal,mover,updateMover),350);
      return;
    }

    // ── 環境感應站：周圍4格設施數×+1 ──
    if(b.special==='env_sensor'){
      const adj=[[r-1,c],[r+1,c],[r,c-1],[r,c+1]];
      const adjCount=adj.filter(([ar,ac])=>ar>=0&&ar<GN()&&ac>=0&&ac<GN()&&G.grid[ar][ac]).length;
      let env_val=el.value+adjCount;
      env_val=applyUpgradeBonus(r,c,env_val,'環境感應站');
      el={...el,value:env_val};
      const es_upg=G.bldgUpgrades?.[`${r},${c}`]||0;
      const es_parts=[`周圍${adjCount}設施+${adjCount}`]; if(es_upg>0) es_parts.push(`升級+${es_upg}`);
      addLog(`  📊 環境感應站: →${el.value}（${es_parts.join('，')}）`);
      G.turnFacilitiesHit=(G.turnFacilitiesHit||0)+1;
      pulse(r,c); updateCard(el);
      setTimeout(()=>stepWithMover(path,el,i+1,startVal,mover,updateMover),350);
      return;
    }

    // ── 外貿港口：商品>10每10+10% ──
    if(b.special==='trade_port' && el.type==='goods'){
      const tiers=Math.floor(el.value/10);
      if(tiers>0){
        let tp_add=Math.floor(el.value*tiers*0.1);
        const tp_upg=G.bldgUpgrades?.[`${r},${c}`]||0;
        tp_add=Math.floor(el.value*tiers*0.1)+tp_upg;
        el={...el,value:el.value+tp_add};
        addLog(`  ⚓ 外貿港口: +${tp_add}（${tiers}階×10%）`,'g');
      }
      G.turnFacilitiesHit=(G.turnFacilitiesHit||0)+1;
      pulse(r,c); updateCard(el);
      setTimeout(()=>stepWithMover(path,el,i+1,startVal,mover,updateMover),350);
      return;
    }

    // ── 匯率波動板：資源直接通過（效果在結算時觸發）──
    if(b.special==='exchange_board'){
      addLog(`  📈 匯率波動板: 資源通過，結算時將隨機調整收益`,'w');
      G._exchangeBoardActive = true;  // 標記本次投入有匯率波動板
      G.turnFacilitiesHit=(G.turnFacilitiesHit||0)+1;
      pulse(r,c); updateCard(el);
      setTimeout(()=>stepWithMover(path,el,i+1,startVal,mover,updateMover),350);
      return;
    }

    // ── 貿易特區：周圍4格有商店時×1.5 ──
    if(b.special==='trade_zone'){
      const adj=[[r-1,c],[r+1,c],[r,c-1],[r,c+1]];
      const hasShop=adj.some(([ar,ac])=>ar>=0&&ar<GN()&&ac>=0&&ac<GN()&&G.grid[ar][ac]==='shop');
      const prevVal=el.value;
      let tz_val=el.value;
      let tz_parts=[];
      if(hasShop){
        tz_val=Math.floor(tz_val*1.05);
        tz_parts.push('相鄰商店×1.05');
      }
      tz_val=applyUpgradeBonus(r,c,tz_val,'貿易特區');
      const upg=G.bldgUpgrades?.[`${r},${c}`]||0;
      if(upg>0) tz_parts.push(`升級+${upg}`);
      el={...el,value:tz_val};
      const calcStr=tz_parts.length?`（${tz_parts.join('，')}）`:'';
      addLog(`  🌏 貿易特區: ${TLABEL[el.type]}${prevVal}→${tz_val}${calcStr}`,'g');
      G.turnFacilitiesHit=(G.turnFacilitiesHit||0)+1;
      pulse(r,c); updateCard(el);
      setTimeout(()=>stepWithMover(path,el,i+1,startVal,mover,updateMover),350);
      return;
    }

    // ── 套利者/外匯：標記轉換方向 ──
    if(el.type==='money') G._tradeMoneyToGoods=false;
    if(el.type==='goods') G._tradeGoodsToMoney=false;

    // ── 清倉拍賣場：商品×4金錢 ──
    if(b.special==='clearance' && el.type==='goods'){
      let cl_val=applyUpgradeBonus(r,c,el.value*4,'清倉拍賣場');
      addLog(`  🏷️ 清倉拍賣場: 📦${el.value}→💰${cl_val}（×4）`,'g');
      el={value:cl_val,type:'money'};
      G.turnFacilitiesHit=(G.turnFacilitiesHit||0)+1;
      pulse(r,c); updateCard(el);
      setTimeout(()=>stepWithMover(path,el,i+1,startVal,mover,updateMover),350);
      return;
    }

    // ── 建築廢料廠：消滅自身，×2 ──
    if(b.special==='demolish_fab'){
      let df_val=applyUpgradeBonus(r,c,el.value*2,'建築廢料廠');
      el={...el,value:df_val};
      addLog(`  🏗 建築廢料廠: ×2→${el.value}，自毀！`,'g');
      destroyFacility(r,c);
      G.turnFacilitiesHit=(G.turnFacilitiesHit||0)+1;
      pulse(r,c); updateCard(el);
      setTimeout(()=>stepWithMover(path,el,i+1,startVal,mover,updateMover),350);
      return;
    }

    // ── 動態加強器：本回合設施被移動過則×2 ──
    if(b.special==='dynamic_amp'){
      const mult=(G._facilitiesMovedThisTurn||0)>0?2:1;
      let da_val=applyUpgradeBonus(r,c,el.value*mult,'動態加強器');
      el={...el,value:da_val};
      const da_upg=G.bldgUpgrades?.[`${r},${c}`]||0;
      const da_parts=[`×${mult}`]; if(mult===2) da_parts.push('有移動'); if(da_upg>0) da_parts.push(`升級+${da_upg}`);
      addLog(`  🔋 動態加強器: →${el.value}（${da_parts.join('，')}）`);
      G.turnFacilitiesHit=(G.turnFacilitiesHit||0)+1;
      pulse(r,c); updateCard(el);
      setTimeout(()=>stepWithMover(path,el,i+1,startVal,mover,updateMover),350);
      return;
    }

    // ── 地基不穩定站：相鄰減益翻倍，相鄰增益-1 ──
    if(b.special==='unstable_base'){
      const adj=[[r-1,c],[r+1,c],[r,c-1],[r,c+1]];
      const adjMods=adj.map(([ar,ac])=>ar>=0&&ar<GN()&&ac>=0&&ac<GN()?(G.cellMods[`${ar},${ac}`]||0):0);
      const hasNeg=adjMods.some(m=>m<0);
      const hasPos=adjMods.some(m=>m>0);
      if(hasNeg){ el={...el,value:el.value*2}; addLog(`  ⚠️ 地基不穩定站: ×2（相鄰有減益）`,'g'); }
      else if(hasPos){ el={...el,value:Math.max(0,el.value-1)}; addLog(`  ⚠️ 地基不穩定站: -1（相鄰有增益）`,'b'); }
      G.turnFacilitiesHit=(G.turnFacilitiesHit||0)+1;
      pulse(r,c); updateCard(el);
      setTimeout(()=>stepWithMover(path,el,i+1,startVal,mover,updateMover),350);
      return;
    }

    // ── 人力派遣：金錢通過 → 獲得1人材，資源不變，不計入收益 ──
    if(b.special==='staffing' && el.type==='money'){
      G.talentCards=(G.talentCards||0)+1;
      addLog(`  🏢 人力派遣：金錢通過，獲得1人材（共${G.talentCards}）`,'g');
      pulse(r,c);
      cellEl?.classList.add('transform-flash');
      setTimeout(()=>cellEl?.classList.remove('transform-flash'),500);
      if(cellEl){
        const badge=document.createElement('div');
        badge.className='change-badge';
        badge.textContent=`🏢 +1🧑‍💼 人材`;
        badge.style.background='var(--blue)';
        cellEl.appendChild(badge);
        setTimeout(()=>badge.remove(),700);
      }
      updateCard(el);
      setTimeout(()=>stepWithMover(path,el,i+1,startVal,mover,updateMover),350);
      return;
    }

    // ── 員工食堂：商品通過 → 獲得1人材 ──
    if(b.special==='cafeteria' && el.type==='goods'){
      G.talentCards=(G.talentCards||0)+1;
      addLog(`  🍱 員工食堂：商品通過，獲得1人材（共${G.talentCards}）`,'g');
      pulse(r,c);
      G.turnFacilitiesHit=(G.turnFacilitiesHit||0)+1;
      updateCard(el);
      setTimeout(()=>stepWithMover(path,el,i+1,startVal,mover,updateMover),350);
      return;
    }

    // ── 物流中心：轉向 ──
    if(b.special==='redirect'){
      // 颱風：物流失效
      if(G.buff&&G.buff.typhoonActive){
        addLog(`  ${b.emoji}${b.name}: 颱風導致物流失效，略過`,'b');
        setTimeout(()=>stepWithMover(path,el,i+1,startVal,mover,updateMover),300);
        return;
      }
      // 每次投入每格只能觸發一次
      const cellKey=`${r},${c}`;
      if(G._triggeredLogistics&&G._triggeredLogistics.has(cellKey)){
        addLog(`  ${b.emoji}${b.name}: 已觸發過，略過`);
        setTimeout(()=>stepWithMover(path,el,i+1,startVal,mover,updateMover),300);
        return;
      }
      if(!G._triggeredLogistics) G._triggeredLogistics=new Set();
      G._triggeredLogistics.add(cellKey);
      // 運輸大亨：每次通過物流+3
      if(hasPartner('transport_tycoon')){
        el={...el,value:el.value+3};
        addLog(`  🚢 運輸大亨：通過物流+3→${el.value}`,'g');
        G._logisticsHitThisTurn=(G._logisticsHitThisTurn||0)+1;
      }
      pulse(r,c);
      cellEl?.classList.add('transform-flash');
      setTimeout(()=>cellEl?.classList.remove('transform-flash'),400);

      // upgrade bonus (for redirect cell itself, not overlay)
      const upgradeBonus=G.bldgUpgrades?.[`${r},${c}`]||0;
      if(upgradeBonus>0){
        el={...el,value:el.value+upgradeBonus};
        addLog(`  ${b.emoji}${b.name}: 轉向 + 升級加成 +${upgradeBonus} → ${el.value}`);
      } else {
        addLog(`  ${b.emoji}${b.name}: 轉向 ${b.dir}`);
      }
      updateCard(el);
      setTimeout(()=>updateMover(el),100);

      // rebuild remaining path from next cell in new direction
      const newDir=b.dir;
      const newPath=[];
      let nr=r,nc=c;
      const visited=new Set();
      visited.add(`${r},${c}`);
      for(let s=0;s<N*4;s++){
        if(newDir==='top')    nr--;
        if(newDir==='bottom') nr++;
        if(newDir==='left')   nc--;
        if(newDir==='right')  nc++;
        if(nr<0||nr>=N||nc<0||nc>=N) break;
        if(visited.has(`${nr},${nc}`)) break; // 防止迴圈
        visited.add(`${nr},${nc}`);
        newPath.push([nr,nc]);
      }

      // 物流之王：先執行疊加設施效果，再轉向
      const overlayId=G.cellOverlay&&G.cellOverlay[`${r},${c}`];
      if(overlayId&&BLDG[overlayId]){
        const ob=BLDG[overlayId];
        const effType2=el.type;
        if(ob.req==='any'||ob.req===effType2){
          const ov_prev={...el};
          const ov_nv=ob.fn(el.value)+(G.bldgUpgrades?.[`${r},${c}`]||0);
          const ov_nt=ob.out||el.type;
          el={value:ov_nv,type:ov_nt};
          addLog(`  🚛 物流之王疊加 ${ob.emoji}${ob.name}: ${TLABEL[ov_prev.type]}${ov_prev.value} → ${TLABEL[el.type]}${el.value}`);
          updateCard(el);
          setTimeout(()=>updateMover(el),100);
        }
      }
      setTimeout(()=>{
        if(newPath.length===0){
          mover.style.display='none';
          document.querySelectorAll('.cell').forEach(c=>c.classList.remove('active-path'));
          finish(el,startVal);
        } else {
          stepWithMover(newPath,el,0,startVal,mover,updateMover);
        }
      },400);
      return;
    }

    // 暴食惡魔：material<->goods 互換用於匹配和輸出
    let effType=el.type;
    if(hasPartner('gluttony')){
      if(el.type==='material') effType='goods';
      else if(el.type==='goods') effType='material';
    }
    if(b.req==='any'||b.req===effType||b.req===el.type){
      // 嫉妒惡魔：進入非嫉妒工廠前若已有設施命中則中斷
      if(hasPartner('envy')&&bId!=='envy_factory'&&b.special!=='envy'){
        if((G.turnFacilitiesHit||0)===0){
          // first hit is non-envy: ok, but flag it
        }
      }
      if(hasPartner('envy')&&bId==='envy_factory'&&(G.turnFacilitiesHit||0)>0){
        addLog('  💚 嫉妒惡魔：已經過其他設施，嫉妒工廠中斷','b');
        setTimeout(()=>{ mover.style.display='none'; document.querySelectorAll('.cell').forEach(c=>c.classList.remove('active-path')); finish(el,startVal); },400);
        return;
      }
      // 嫉妒工廠負面：投入時非鑽石則最終收益-50%
      if(bId==='envy_factory' && el.type!=='diamond'){
        G._envyPenalty=true;
        addLog('  💚 嫉妒工廠：非鑽石投入，最終收益將-50%','b');
      }
      // 暴食惡魔：若匹配是因為互換，則視為互換類型進入
      if(hasPartner('gluttony')&&b.req===effType&&b.req!==el.type) el={...el,type:effType};
      G.turnFacilitiesHit=(G.turnFacilitiesHit||0)+1;
      if(isCenterCell(r,c)){ G._centerHits=(G._centerHits||0)+1; G._highwayPassedCenter=true; }
      // 物流放大器：本設施效果×2
      if(G._logisticsAmpActive){ nv=nv*2; G._logisticsAmpActive=false; addLog(`  📡 物流放大器：×2 → ${nv}`,'g'); }
      // 廢墟掠奪者：廢墟格+5
      if(hasPartner('ruin_scavenger')&&G.ruinCells&&G.ruinCells.has(`${r},${c}`)&&!G.grid[r][c]){ el={...el,value:el.value+5}; addLog(`  💀 廢墟掠奪者：廢墟格+5→${el.value}`,'g'); }
      const prev={...el};
      const modKey=`${r},${c}`;
      const upgradeBonus=(!b.special||b.special==='cafeteria')&&G.bldgUpgrades?.[modKey]||0;

      // ── Step 1: 基礎轉換 ──
      let nv=b.fn(el.value);
      let nt=b.out||el.type;

      // 暴食惡魔：輸出類型互換
      if(hasPartner('gluttony')){
        if(nt==='material') nt='goods';
        else if(nt==='goods') nt='material';
      }

      // ── Step 2: 百分比加成（先處理） ──
      // 原料出口熱 ×2
      if(G.buff.matOutMult&&prev.type==='material'&&nt!=='material'){
        nv=Math.round(nv*G.buff.matOutMult);
      }
      if(G.buff.matToMoneyDouble&&prev.type==='material'&&nt==='money'){
        nv=nv*2;
        addLog(`  🌀 颱風：原料→金錢翻倍！`,'w');
      }

      // ── Step 3: 格子固定加成 + 升級加成（後處理） ──
      let cellMod=G.cellMods[modKey]||0;
      // 激情惡魔：逆轉減益
      if(cellMod<0 && hasPartner('wrath')){
        cellMod=-cellMod;
        addLog(`  🔥 激情惡魔：減益逆轉 → +${cellMod}`,'g');
        G.partnerState.wrath=G.partnerState.wrath||{noDebuffTurns:0};
        G.partnerState.wrath.noDebuffTurns=0;
      }
      // 固定加成：cellMod + upgrade（兩者都是固定+x，合併後加）
      const totalFixed=cellMod+upgradeBonus;
      if(totalFixed!==0) nv=Math.max(0,nv+totalFixed);

      // ── Step 4: 商品熱銷固定加成（+x類，在%之後）──
      if(G.buff.goodsBonus&&prev.type==='goods'&&nt==='money'){
        nv+=G.buff.goodsBonus;
      }

      // ── Step 5: 下次輸出加成（nextBonus）──
      if(G.nextBonus&&G.nextBonus.amount>0){
        if(G.nextBonus.type==='any'||G.nextBonus.type===nt){
          nv+=G.nextBonus.amount;
          addLog(`  ✨ 下次輸出加成：+${G.nextBonus.amount}（${TLABEL[nt]}輸出）`,'g');
          G.nextBonus=null; // 消耗一次
        }
      }

      el={value:nv,type:nt};

      pulse(r,c);
      cellEl?.classList.add('transform-flash');
      setTimeout(()=>cellEl?.classList.remove('transform-flash'),500);

      if(cellEl){
        const badge=document.createElement('div');
        badge.className='change-badge';
        badge.textContent=`${b.emoji} ${TLABEL[prev.type]}${prev.value}→${TLABEL[el.type]}${el.value}${el.value!==prev.value?` (+${el.value-prev.value})`:''}`;
        badge.style.background=TCOLOR[el.type]||'var(--green)';
        cellEl.style.position='relative';
        cellEl.appendChild(badge);
        setTimeout(()=>badge.remove(),700);
      }

      // partner onBuildingHit
      G.partners.forEach(pid=>{
        const p=PARTNERS[pid];
        if(p&&p.onBuildingHit){
          const profitBefore=G.profit;
          p.onBuildingHit(G,G.grid[r][c]);
          const gained=G.profit-profitBefore;
          if(gained>0){
            addLog(`★ ${p.emoji}${p.name}：+${gained} 收益`,'g');
            setTimeout(()=>profitFlyFromPartner(pid,gained),200);
          }
        }
      });
      const upgrade=upgradeBonus;
      // 建立算式說明（包含所有加成）
      let calcParts=[];
      const baseChg=b.fn(1)-1;
      if(baseChg!==0||nt!==prev.type) calcParts.push(`基礎${baseChg>=0?'+':''}${baseChg}`);
      if(G.buff.matOutMult&&prev.type==='material'&&nt!=='material') calcParts.push(`出口熱×${G.buff.matOutMult}`);
      if(G.buff.matToMoneyDouble&&prev.type==='material'&&nt==='money') calcParts.push(`颱風×2`);
      if(upgrade>0) calcParts.push(`升級+${upgrade}`);
      if(cellMod>0) calcParts.push(`格子+${cellMod}`);
      if(cellMod<0) calcParts.push(`格子${cellMod}`);
      if(G.buff.goodsBonus&&prev.type==='goods'&&nt==='money') calcParts.push(`熱銷+${G.buff.goodsBonus}`);
      const calcStr=calcParts.length?`（${calcParts.join('，')}）`:'';
      addLog(`  ${b.emoji}${b.name}: ${TLABEL[prev.type]}${prev.value}→${TLABEL[el.type]}${el.value}${calcStr}`);
      updateCard(el);
      setTimeout(()=>{
        updateMover(el);
        setTimeout(()=>stepWithMover(path,el,i+1,startVal,mover,updateMover),350);
      },350);
      return;
    } else {
      // 類型不符：略過此格，繼續前進
      addLog(`  ⏭ ${b.emoji}${b.name} 類型不符（需要 ${TLABEL[b.req]}），略過`);
    }
  }
  setTimeout(()=>stepWithMover(path,el,i+1,startVal,mover,updateMover),300);
}

function finish(el,startVal){
  document.querySelectorAll('.cell').forEach(c=>c.classList.remove('active-path'));
  // Tutorial hook: after send - check if mat_factory was hit (回合1)
  if(TUT.active && TUT.waitingFor==='send_el'){
    const hitMatFactory = G._tutHitMatFactory;
    G._tutHitMatFactory = false;
    TUT.waitingFor = null;
    setTimeout(()=>{
      // 如果通過原料廠，原料返回 G.card
      if(hitMatFactory && el.type === 'material'){
        G.card = {value: el.value, type: 'material'};
      } else {
        G.card = null;
      }
      // 回合1結束，推進到回合2
      G.turn = 2;
      G.phase = 'place';
      render();
      renderFanHand();
      if(hitMatFactory){
        TUT.speak([
          '金錢通過了原料廠，變成了原料！',
          '不過……原料不是金錢，所以收益還是零。',
        ], ()=>{
          // 進入 step5（給工廠和商店）
          TUT.step = 4;
          TUT.next();
        });
      } else {
        TUT.speak([
          '金錢直接穿過格子，沒有通過原料廠……',
          '所以資源沒有被轉換，收益是零。',
        ], ()=>{
          // 進入 step5（給工廠和商店）
          TUT.step = 4;
          TUT.next();
        });
      }
    }, 800);
    // 教學模式下不執行後續的正常遊戲結算邏輯
    return;
  }
  // Tutorial hook: step6 投入金錢獲得收益（回合2）
  if(TUT.active && TUT.waitingFor==='tut_send_for_profit'){
    TUT.waitingFor = null;
    // 正常執行收益結算，但之後進入 step7
    // 不 return，讓後續正常結算邏輯執行
  }
  // talent_coin exits without shop: face value
  if(el.type==='talent_coin') el={value:el.value,type:'money'};
  // Diamond exits without shop: convert at face value (no bonus)
  if(el.type==='diamond') el={value:el.value,type:'money'};
  // Lust demon
  if(hasPartner('lust')){
    el=PARTNERS.lust.modifyFinish(G,el,G.turnFacilitiesHit||0);
  }
  const finalMoney=el.type==='money'?el.value:Math.floor(el.value*0.6);
  const profit=Math.max(0,finalMoney-startVal);
  const profitAtStart=G.profit;
  G.profit+=profit;
  // 匯率波動板：本次投入有通過匯率波動板，隨機調整收益
  if(G._exchangeBoardActive && profit > 0){
    const pcts = [-15,-12,-10,-8,-5,-3,3,5,8,10,12,15];
    const pct = pcts[Math.floor(Math.random()*pcts.length)];
    const adj = Math.round(profit * pct / 100);
    G.profit += adj;
    addLog(`📈 匯率波動板：結算隨機 ${pct>0?'+':''}${pct}% → ${adj>0?'+':''}${adj} 收益（共${G.profit}）`, adj>=0?'g':'b');
    G._exchangeBoardActive = false;
  }
  // 工會主席：人材加成/懲罰
  if(hasPartner('union_chief')){
    if((G.talentCards||0)>=3){
      const bonus=Math.ceil(profit*0.5);
      G.profit+=bonus; addLog(`✊ 工會主席：3+人材，+50% → +${bonus}`,'g');
    } else if(profit>0){
      const cut=Math.floor(profit*0.2);
      G.profit-=cut; addLog(`✊ 工會主席：人材不足，-20% -${cut}`,'b');
    }
  }
  // 場風大師：正確方向投入 ×2
  if(hasPartner('wind_master') && G._windCorrect){
    const bonus=profit; // double
    G.profit+=bonus;
    addLog(`🌀 場風大師：正確方向，收益×2 +${bonus}`,'g');
    setTimeout(()=>profitFlyFromPartner('wind_master',bonus),100);
    G._windCorrect=false;
  }
  // Partner: pride - 10% per demon (including pride itself), ceil
  if(hasPartner('pride')){
    const demonCount=G.partners.filter(pid=>PARTNERS[pid]&&PARTNERS[pid].isDemon).length;
    if(demonCount>0){
      const bonus=Math.ceil(profit*demonCount*0.1);
      G.profit+=bonus;
      addLog(`👑 傲慢惡魔：${demonCount}個惡魔，收益+${demonCount*10}% → +${bonus}`,'g');
      setTimeout(()=>profitFlyFromPartner('pride',bonus),150);
    }
  }
  // Partner: poverty_god
  if(hasPartner('poverty_god')) PARTNERS.poverty_god.onFinish(G, profit);
  // Partner: greed - 50% bonus at turn end
  if(hasPartner('greed')&&(!isDemonNegDisabled()||true)){
    // pos always active; neg (goal+50%) handled in onRoundStart
    PARTNERS.greed.onTurnEnd(G, profit);
  }
  // Partner: wrath - track debuff turns (simplified: no debuff this turn = no cellMod)
  if(hasPartner('wrath')){
    const hadDebuff=Object.values(G.cellMods||{}).some(v=>v<0);
    PARTNERS.wrath.onTurnEnd(G, hadDebuff);
  }
  // 快遞達人
  if(hasPartner('express_master')){
    if((G.turnFacilitiesHit||0)>=4){
      const bonus=Math.ceil(profit*0.1);
      G.profit+=bonus;
      addLog(`🚀 快遞達人：${G.turnFacilitiesHit}格，+10% → +${bonus}`,'g');
    } else if(profit>0){
      const cut=Math.floor(profit*0.5);
      G.profit-=cut;
      addLog(`🚀 快遞達人：不足4格（${G.turnFacilitiesHit}），收益減半-${cut}`,'b');
    }
  }
  // 公路之星：未經中央則收益減半
  if(hasPartner('highway_star')&&!G._highwayPassedCenter&&profit>0){
    const cut=Math.floor(profit*0.5);
    G.profit-=cut;
    addLog(`🌟 公路之星：未經中央，收益減半 -${cut}`,'b');
  }
  // 市長：+5%每次經過中央
  if(hasPartner('mayor')&&(G._centerHits||0)>0&&profit>0){
    const pct=G._centerHits*5;
    const bonus=Math.ceil(profit*pct/100);
    G.profit+=bonus;
    addLog(`🎖 市長：經過中央${G._centerHits}次，+${pct}% → +${bonus}`,'g');
    setTimeout(()=>profitFlyFromPartner('mayor',bonus),150);
  }
  // 稅務局：-10%最終收益
  if(profit>0){
    let hasTax=false;
    for(let r=0;r<GN();r++) for(let cc=0;cc<GN();cc++) if(G.grid[r][cc]==='tax_office') hasTax=true;
    if(hasTax){
      const cut=Math.ceil(profit*0.1);
      G.profit-=cut;
      addLog(`  🏛 稅務局：-10% (-${cut})`,'b');
    }
  }
  if(G._envyPenalty && profit>0){
    const cut=Math.floor(profit*0.5);
    G.profit-=cut;
    addLog(`💚 嫉妒工廠負面：收益-50% (-${cut})`,'b');
    G._envyPenalty=false;
  }
  addLog(`💰 結算：${TLABEL[el.type]}${el.value} → 入帳${finalMoney}，+${profit}收益`,'g');

  // 收益飛行動畫
  const profitEl=document.getElementById('el-profit');
  const profitRect=profitEl.getBoundingClientRect();
  const targetEl=document.getElementById('r-profit');
  const targetRect=targetEl.getBoundingClientRect();
  const fly=document.createElement('div');
  fly.className='profit-fly';
  fly.textContent=`+${profit}`;
  fly.style.left=profitRect.left+'px';
  fly.style.top=profitRect.top+'px';
  const dx=targetRect.left-profitRect.left;
  fly.style.setProperty('--tx',dx+'px');
  document.body.appendChild(fly);
  setTimeout(()=>fly.remove(),1300);

  // 計算本回合總收益（含所有合夥人加成）並更新顯示
  const totalTurnProfit=G.profit-profitAtStart;
  const hasBonus=totalTurnProfit!==profit;
  let profitHTML=`<span style="color:var(--green);font-size:18px;">+${totalTurnProfit}</span>`;
  if(hasBonus) profitHTML+=`<div style="font-size:9px;color:var(--mu);margin-top:2px;">投入+${profit}，加成${totalTurnProfit-profit>=0?'+':''}${totalTurnProfit-profit}</div>`;
  document.getElementById('el-profit').innerHTML=profitHTML;

  if((G.elementExtraUses||0)>0){
    G.elementExtraUses--;
    addLog(`🧑‍💼 人材效果：可再投入一次（剩餘 ${G.elementExtraUses} 次）`,'g');
    G.phase='place';
  } else {
    G.phase='done';
  }
  updateCard(el);
  render();

  // Tutorial hook: step6 投入完成後，提示點擊結束回合
  if(TUT.active && G.phase==='done' && TUT.step===6 && !TUT.waitingFor){
    setTimeout(()=>{
      if(totalTurnProfit > 0){
        TUT.speak([
          `太棒了！你獲得了 +${totalTurnProfit} 收益！`,
          '現在點擊「結束回合」按鈕吧！',
        ], ()=>{
          TUT.waitingFor = 'tut_end_turn_for_partner';
        });
      } else {
        TUT.speak([
          '哎呀，這次沒有獲得收益……',
          '可能是設施的排列方式不對，讓資源沒有正確轉換成金錢。',
          '沒關係，先點「結束回合」繼續吧！',
        ], ()=>{
          TUT.waitingFor = 'tut_end_turn_for_partner';
        });
      }
    }, 500);
    return;
  }

  if(G.profit>=G.goal){
    setTimeout(()=>{
      const oldRound=G.round; const oldGoal=G.goal;
      G.round++; G.goal=Math.round(G.goal*1.8+15);
      G.turn=1; G.buff={}; G.sel=null; G.cellMods={};
      
      showModal('win',`第 ${oldRound} 輪過關！\n達成目標 ${oldGoal}\n\n第 ${G.round} 輪新目標：${G.goal}`);
    },600);
  }
}

// ══════════════════════════════════════
// 8種行動選項池
// ══════════════════════════════════════
const ACTION_POOL = [
  { id:'buy_fac',   label:'🏗 購買設施',         cost:4, desc:'從設施池隨機取3個，選1加入手牌' },
  { id:'trig_ev',   label:'⚡ 觸發隨機事件',      cost:2, desc:'立即觸發一個隨機事件' },
  { id:'move_fac',  label:'🔧 重新排列設施',       cost:2, desc:'自由移動所有設施，確定後鎖定' },
  { id:'get_partner',label:'🤝 招募合夥人',         cost:5, desc:'隨機招募一位合夥人' },
  { id:'upgrade',   label:'⬆ 提升設施數值',       cost:3, desc:'選一個設施，永久提升輸出 +1' },
  { id:'next_bonus',label:'✨ 下次輸出加成',       cost:3, desc:'下次元素以商品/原料/金錢輸出時 +3' },
  { id:'swap_ev',   label:'🔄 更換預告事件',       cost:1, desc:'重新抽一個下回合的隨機事件' },
  { id:'nothing',   label:'😴 什麼也沒發生',       cost:0, desc:'跳過行動，保留收益' },
];

function pickActionOptions(){
  const shuffled=[...ACTION_POOL].sort(()=>Math.random()-.5);
  G.actionOptions=shuffled.slice(0,2);
}

function pickNextEvent(){
  // 預告下一個 EVENT_INTERVAL 倍數回合的事件
  const nextEvTurn = Math.ceil((G.turn+1)/EVENT_INTERVAL)*EVENT_INTERVAL;
  G.nextEvent=EVENTS[Math.floor(Math.random()*EVENTS.length)];
  G.nextEventTurn=nextEvTurn;
}

function doAction(id){
  // 立即關閉卡牌
  document.getElementById('action-chooser').style.display='none';
  const act=ACTION_POOL.find(a=>a.id===id);
  if(!act)return;
  const actCost=Math.ceil(act.cost*Math.max(1,(1+(G.round-1)*0.5)));
  if(G.profit<actCost){ addLog(`⚠ 收益不足（需要 ${actCost}，現有 ${G.profit}）`,'b'); return; }
  G.profit-=actCost;

  if(id==='buy_fac'){
    const pool=Object.keys(BLDG).filter(bid=>bid!=='envy_factory').sort(()=>Math.random()-.5).slice(0,3);
    const refund=actCost;
    showCardChooser(
      '🏗 選擇一個設施加入手牌',
      pool.map(bid=>({
        emoji:BLDG[bid].emoji, name:BLDG[bid].name,
        desc:BLDG[bid].desc, pos:'', neg:'',
        onclick:`cardChooserPick(()=>{evPick('${bid}',null)})`
      })),
      ()=>{G.profit+=refund; closeActionOverlay(); G.actionOptions=[]; startTurn();}
    );
    G.phase='event'; render(); return;
  }
  if(id==='trig_ev'){
    triggerEvent(); return;
  }
  if(id==='move_fac'){
    // 進入自由排列模式（無論是否有拆遷隊都一樣）
    G.freeRearrange=true; G.moveMode=false; G.moveSrc=null;
    addLog('🔧 自由排列模式：隨意移動設施，點「確認排列」鎖定');
    G.phase='place'; render(); return;
  }
  if(id==='get_partner'){
    const pool=Object.keys(PARTNERS).filter(pid=>!hasPartner(pid));
    if(!pool.length){addLog('⚠ 已招募所有合夥人','b');G.profit+=actCost;startTurn();return;}
    const picks=pool.sort(()=>Math.random()-.5).slice(0,3);
    const refund=actCost;
    showCardChooser(
      '🤝 招募合夥人',
      picks.map(pid=>({
        emoji:PARTNERS[pid].emoji, name:PARTNERS[pid].name,
        desc:PARTNERS[pid].desc||'',
        pos:PARTNERS[pid].pos||'', neg:PARTNERS[pid].neg||'',
        onclick:`cardChooserPick(()=>{recruitPartner('${pid}')})`
      })),
      ()=>{G.profit+=refund; closeActionOverlay(); G.actionOptions=[]; startTurn();}
    );
    G.phase='event'; render(); return;
  }
  if(id==='upgrade'){
    const filled=[];
    for(let r=0;r<N;r++) for(let cc=0;cc<N;cc++) if(G.grid[r][cc]) filled.push([r,cc]);
    if(!filled.length){addLog('⚠ 沒有可提升的設施','b');G.profit+=act.cost;startTurn();return;}
    G.upgradeMode=true;
    G.phase='place';
    addLog('⬆ 點擊想要提升的設施（永久 +1 輸出）','w');
    render();
    return;
  }
  if(id==='next_bonus'){
    const types=['money','material','goods'];
    const t=types[Math.floor(Math.random()*types.length)];
    G.nextBonus={type:t,amount:3};
    addLog(`✨ 下次 ${TLABEL[t]} 輸出時額外 +3`,'g');
  }
  if(id==='swap_ev'){
    pickNextEvent();
    addLog(`🔄 預告事件已更換為：${G.nextEvent.title}`,'g');
  }
  if(id==='nothing'){
    addLog('😴 什麼也沒發生，收益保留');
  }

  closeActionOverlay();
  G.actionOptions=[];
  startTurn();
}

function upgradeCell(r,c){
  hideEv();
  const bId=G.grid[r][c];
  if(!bId) return;
  const b=BLDG[bId];
  const key=`${r},${c}`;
  G.bldgUpgrades[key]=(G.bldgUpgrades[key]||0)+1;
  addLog(`⬆ ${b.emoji}${b.name} (${r+1},${c+1}) 升級！+${G.bldgUpgrades[key]}`,'g');
  G.upgradeMode=false;
  G.actionOptions=[];
  pulse(r,c);
  G.phase='place'; render();
}

function recruitPartner(pid){
  G.partners.push(pid);
  if(PARTNERS[pid]&&PARTNERS[pid].onRecruit) PARTNERS[pid].onRecruit(G);
  if(!G.partnerState[pid]&&PARTNERS[pid].state) G.partnerState[pid]={...PARTNERS[pid].state};
  addLog(`🤝 招募了 ${PARTNERS[pid].emoji}${PARTNERS[pid].name}！`,'g');
  if(pid==='envy') addHand('envy_factory');
  G.actionOptions=[];
  closeActionOverlay();
  startTurn();
}

function cancelRearrange(){
  G.freeRearrange=false; G.moveSrc=null;
  addLog('↩ 取消排列');
  render();
}
function confirmRearrange(){
  // 只有從拆遷隊啟動的重排才扣次數
  if(G._demolitionRearrange && hasPartner('demolition')){
    G.demolitionCharges=Math.max(0,(G.demolitionCharges||0)-1);
    addLog(`🔨 拆遷隊使用 1 次，剩餘 ${G.demolitionCharges} 次`,'g');
  }
  G._demolitionRearrange = false;
  G.freeRearrange=false; G.moveSrc=null;
  addLog('✅ 設施排列已確定','g');
  render();
  // 教學 hook：確認排列後進入 step9
  if(TUT.active && TUT.waitingFor === 'confirm_rearrange'){
    TUT.waitingFor = null;
    setTimeout(()=>TUT.next(), 500);
  }
}

function startTurn(){
  G.phase='place';
  // 合夥人每回合開始效果
  G.partners.forEach(pid=>{
    const p=PARTNERS[pid];
    if(p&&p.onTurnStart) p.onTurnStart(G);
  });

  // 爆破裝置：倒數計時
  for(let r=0;r<GN();r++) for(let cc=0;cc<GN();cc++){
    if(G.grid[r][cc]==='bomb_device'){
      const key=`${r},${cc}`;
      if(!G.bombTimers) G.bombTimers={};
      if(G.bombTimers[key]===undefined) G.bombTimers[key]=3;
      G.bombTimers[key]--;
      if(G.bombTimers[key]<=0){
        // Explode: +3 to adjacent cells
        [[r-1,cc],[r+1,cc],[r,cc-1],[r,cc+1]].forEach(([ar,ac])=>{
          if(ar>=0&&ar<GN()&&ac>=0&&ac<GN()){
            G.cellMods[`${ar},${ac}`]=(G.cellMods[`${ar},${ac}`]||0)+3;
          }
        });
        addLog(`💣 爆破裝置 (${r+1},${cc+1}) 爆炸！周圍4格+3`,'b');
        destroyFacility(r,cc);
        delete G.bombTimers[key];
      } else {
        addLog(`💣 爆破裝置 (${r+1},${cc+1}) 倒數 ${G.bombTimers[key]} 回合`);
      }
    }
  }


  // 匯率波動板：效果移至結算時觸發（無需每回合預算）

  // 人力訓練中心：每回合+1人材
  for(let r=0;r<GN();r++) for(let cc=0;cc<GN();cc++){
    if(G.grid[r][cc]==='talent_training'){
      G.talentCards=(G.talentCards||0)+1;
      addLog(`🎓 人力訓練中心 (${r+1},${cc+1})：+1人材（共${G.talentCards}）`,'g');
    }
  }
  // 公路之星：每回合中央隨機2格+2效果，每10回合額外+2
  if(hasPartner('highway_star')){
    const centerList=[...getCenterCells()].sort(()=>Math.random()-.5).slice(0,2);
    const bonus = 2 + (G.turn % 10 === 0 ? 2 : 0);
    centerList.forEach(key=>{
      G.cellMods[key]=(G.cellMods[key]||0)+bonus;
    });
    if(G.turn % 10 === 0){
      addLog(`🌟 公路之星：中央2格獲得+${bonus}（第10回合加成！）（${centerList.join(' ')}）`,'g');
    } else {
      addLog(`🌟 公路之星：中央2格獲得+${bonus}（${centerList.join(' ')}）`,'g');
    }
    G._highwayPassedCenter=false;
  }
  // 場風大師：每回合重新抽方向
  if(hasPartner('wind_master')){
    const dirs=['left','right','top','bottom'];
    const labels={left:'← 左側',right:'→ 右側',top:'↑ 上方',bottom:'↓ 下方'};
    G.windDir=dirs[Math.floor(Math.random()*dirs.length)];
    addLog(`🌀 場風大師：本回合只能從 ${labels[G.windDir]} 投入，獲得×2倍率`,'w');
  } else {
    G.windDir=null;
  }
  addLog(`── 回合 ${G.turn}/${G.maxTurns} ──`);
  render();
  if(hasPartner('tanya')){
    tanyaOfferSwap(); // 譚雅：先交換再選行動
  } else {
    openActionOverlay();
  }
}

// ══════════════════════════════════════
// 回合推進
// ══════════════════════════════════════
function scaledCost(base){
  return Math.ceil(base*Math.max(1,(1+(G.round-1)*0.5)));
}
function doNext(){
  if(G.phase!=='done')return;
  // Tutorial hook
  if(TUT.active && TUT.waitingFor==='end_turn'){ TUT.onAction('end_turn'); return; }
  // Tutorial hook: step6 結束回合後進入 step7（回合3）
  if(TUT.active && TUT.waitingFor==='tut_end_turn_for_partner'){
    G.turn = 3; // 推進到回合3
    render();
    TUT.waitingFor = null;
    TUT.step = 6;
    TUT.next();
    return;
  }
  // 教學模式下，如果沒有預期的 waitingFor，不執行正常回合推進
  if(TUT.active){
    return;
  }

  // 每回合結束清除格子修正（只持續一回合）
  G.cellMods={};
  G.buff={};G.sel=null;G.moveMode=false;G.moveSrc=null;

  // 回合用盡（未達標）→ 失敗
  if(G.turn>=G.maxTurns){
    showModal('lose',`第 ${G.round} 輪失敗！\n收益 ${G.profit} / 目標 ${G.goal}\n差距 ${G.goal-G.profit}`);
    return;
  }

  G.turn++;

  // 每 EVENT_INTERVAL 回合觸發固定隨機事件
  if(G.turn%EVENT_INTERVAL===0 && G.nextEvent){
    const ev=G.nextEvent;
    G.nextEvent=null;
    G.cellMods={}; // 確保事件效果從乾淨狀態套用
    G.phase='event';
    ev.show(ev);
    pickNextEvent();
    render();
    return;
  }

  // 產生本回合2個行動選項
  pickActionOptions();
  startTurn();
}

function openActionOverlay(){
  const chooser=document.getElementById('action-chooser');
  const cards=document.getElementById('action-cards');
  DM.onActionOpen();
  if(!G.actionOptions||G.actionOptions.length===0){chooser.style.display='none';return;}
  // Check if player can afford any option
  const canAffordAny=G.actionOptions.some(a=>G.profit>=scaledCost(a.cost));
  cards.innerHTML=G.actionOptions.map(act=>{
    const sc=scaledCost(act.cost);
    const canAfford=G.profit>=sc;
    return `<div class="acard ${!canAfford?'acard-disabled':''}" onclick="${canAfford?`doAction('${act.id}')`:''}" onmouseenter="DM.onActionHover('${act.label.replace(/^[^\u4e00-\u9fa5a-zA-Z]+/, '')}')" style="cursor:${canAfford?'pointer':'not-allowed'}">
      <div class="acard-label">${act.label}</div>
      <div class="acard-desc">${act.desc}</div>
      <div class="acard-cost ${act.cost===0?'free':''}">${act.cost===0?'免費':'-'+sc+' 收益'}</div>
    </div>`;
  }).join('');
  // Hide skip button if player can afford options (must choose)
  const skipBtn=chooser.querySelector('button[onclick="closeActionOverlay()"]');
  if(skipBtn) skipBtn.style.display=canAffordAny?'none':'block';
  chooser.style.display='flex';
}
function closeActionOverlay(){
  document.getElementById('action-chooser').style.display='none';
  // sloth demon: trigger on skip
  if(hasPartner('sloth')&&G.actionOptions&&G.actionOptions.length>0){
    PARTNERS.sloth.onSkipAction(G);
  }
  G.actionOptions=[];
}
let modalMode='';
function showModal(mode,msg){
  modalMode=mode;
  document.getElementById('memo').textContent=mode==='win'?'🎉':'😔';
  document.getElementById('mtitle').textContent=mode==='win'?'過關！':'失敗…';
  document.getElementById('mmsg').textContent=msg;
  document.getElementById('modal').classList.add('show');
}
function onMBtn(){
  document.getElementById('modal').classList.remove('show');
  if(modalMode==='win'){
    startRound();
  } else {
    G=newGame(); startRound();
  }
}

// ══════════════════════════════════════
// RENDER
// ══════════════════════════════════════
function render(){
  document.getElementById('r-turn').textContent=`第${G.round}輪 回合${G.turn}/${G.maxTurns}`;
  document.getElementById('r-profit').textContent=G.profit;
  document.getElementById('r-goal').textContent=G.goal;
  const pct=Math.min(100,Math.round(G.profit/G.goal*100));
  document.getElementById('pbar-fill').style.width=pct+'%';


  // 同步卡牌 UI（fan hand handles display)
  if(G.card) updateCard(G.card);

  // 提升設施提示橫幅
  document.getElementById('upgrade-hint').classList.toggle('show', !!G.upgradeMode);

  // 場風大師 / 颱風方向提示
  const windHint=document.getElementById('wind-hint');
  if(windHint){
    const isTyphoon=G.buff&&G.buff.typhoonActive;
    const isWind=hasPartner('wind_master');
    if((isWind||isTyphoon)&&G.windDir&&G.phase==='place'){
      const dirLabels={left:'← 左側',right:'→ 右側',top:'↑ 上方',bottom:'↓ 下方'};
      const dirArrows={left:'←',right:'→',top:'↑',bottom:'↓'};
      const icon=isTyphoon?'🌀 颱風：':'🌀 場風大師：';
      const extra=isTyphoon?' （物流失效，原料→金錢翻倍）':'（獲得×2倍率）';
      windHint.style.display='flex';
      windHint.style.background=isTyphoon?'rgba(122,26,26,.1)':'rgba(26,78,122,.1)';
      windHint.style.borderColor=isTyphoon?'rgba(122,26,26,.25)':'rgba(26,78,122,.25)';
      windHint.style.color=isTyphoon?'var(--red)':'var(--blue)';
      document.getElementById('wind-hint-text').textContent=`${icon}本回合只能從 ${dirLabels[G.windDir]} 投入 ${extra}`;
      document.getElementById('wind-dir-arrow').textContent=dirArrows[G.windDir];
    } else {
      windHint.style.display='none';
    }
  }

  document.getElementById('btn-next').disabled=G.phase!=='done';



  // 行動選項按鈕（右側面板，點擊開啟卡牌 overlay）

  renderGrid();
  renderHand();
  renderPartners();
  renderFanHand();
  renderTalentPanel();
  renderSideLog();
}

function renderPartners(){
  const row = document.getElementById('partner-row');
  const section = document.getElementById('partner-section');
  if(!row||!section) return;
  section.style.display='block';
  if(!G.partners||G.partners.length===0){
    row.innerHTML='<div style="font-size:9px;color:var(--hi);padding:4px 0;">尚無合夥人</div>';
    return;
  }
  row.innerHTML = G.partners.map((pid,i) => {
    const p = PARTNERS[pid];
    if(!p) return '';
    const isDemon = p.isDemon ? ' demon' : '';
    const tip = [p.name, p.pos?'✓ '+p.pos:'', p.neg&&p.neg!=='無'?'✕ '+p.neg:'']
      .filter(Boolean).join('|').replace(/"/g,'&quot;');
    const isDemo=pid==='demolition';
    const charges=isDemo?(G.demolitionCharges||0):0;
    const clickable=isDemo&&charges>0;
    const avatarSrc = PARTNER_AVATARS && PARTNER_AVATARS[pid];
    const emojiHtml = avatarSrc
      ? `<img src="${avatarSrc}" class="jc-avatar" alt="${p.name}">`
      : `<div class="jc-emoji">${p.emoji}</div>`;
    return `<div class="joker-card${isDemon}" style="z-index:${i+1};${clickable?'cursor:pointer;':''}"
      data-tip="${tip}"
      onmouseenter="tipFromAttr(event,this); DM.onPartnerHover('${p.name}')"
      onmouseleave="hideTooltip()"
      ${clickable?`onclick="useDemolition()"`:''}>
      ${emojiHtml}
      <div class="jc-name">${p.name}</div>
      ${isDemo&&charges>0?`<div style="font-size:9px;font-weight:700;background:var(--acc);color:#fff;border-radius:99px;padding:1px 6px;margin-top:2px;">×${charges}</div>`:''}
    </div>`;
  }).join('');
}



function renderGrid(){
  const area=document.getElementById('grid-area');
  const isPlace=G.phase==='place';
  let h='';

  // 預告事件顯示在格子上方
  if(G.nextEvent){
    h+=`<div style="width:100%;background:rgba(179,58,0,.08);border:1px solid rgba(179,58,0,.2);border-radius:8px;padding:6px 10px;margin-bottom:6px;font-size:10px;">
      <span style="color:var(--acc);font-weight:700;">回合${G.nextEventTurn||'?'}預告 ▸</span>
      <strong style="margin-left:4px;">${G.nextEvent.title}</strong>
      <span style="color:var(--mu);margin-left:6px;">${G.nextEvent.desc}</span>
    </div>`;
  }

  // 場風大師：標示允許的方向
  // 場風大師或颱風時都要限制方向
  const windDir=(hasPartner('wind_master')||(G.buff&&G.buff.typhoonActive))?G.windDir:null;

  // 上排方向按鈕（拖曳卡牌時才顯示）
  h+=`<div class="drow"><div style="width:28px"></div>`;
  const _gn=GN();
  for(let ci=0;ci<_gn;ci++) h+=`<button class="dbtn${windDir==='top'?' wind-active':windDir?' wind-blocked':''}"
    ondragover="onDirDragOver(event,this)"
    ondragleave="onDirDragLeave(this)"
    ondrop="onDirDrop(event,'top',${ci})">↓</button>`;
  h+=`<div style="width:28px"></div></div>`;

  // 中
  h+=`<div class="dcol-wrap">`;
  h+=`<div class="dside">`;
  for(let ri=0;ri<_gn;ri++) h+=`<button class="dbtn side${windDir==='left'?' wind-active':windDir?' wind-blocked':''}"
    ondragover="onDirDragOver(event,this)"
    ondragleave="onDirDragLeave(this)"
    ondrop="onDirDrop(event,'left',${ri})">→</button>`;
  h+=`</div>`;

  const gn=GN();
  h+=`<div id="grid" style="grid-template-columns:repeat(${gn},var(--cell))">`;
  for(let r=0;r<gn;r++) for(let c=0;c<gn;c++){
    const bId=G.grid[r][c];const b=bId?BLDG[bId]:null;
    const cls='cell'+(b?' filled':'');
    const modVal=G.cellMods?G.cellMods[`${r},${c}`]||0:0;
    const moveSrcHi=(G.moveMode||G.freeRearrange)&&G.moveSrc&&G.moveSrc[0]===r&&G.moveSrc[1]===c?' move-src':'';
    const upgradeHi=G.upgradeMode&&G.grid[r][c]?' upgrade-glow':'';
    const rearrangeHi=G.freeRearrange&&G.grid[r][c]&&!G.moveSrc?' upgrade-glow':'';
    const centerHi=isCenterCell(r,c)?' center-cell':'';
    const ruinHi=(G.ruinCells&&G.ruinCells.has(`${r},${c}`)&&!G.grid[r][c])?' ruin-cell':'';
    const isCenter=isCenterCell(r,c);
    h+=`<div class="${cls}${moveSrcHi}${upgradeHi}${rearrangeHi}${centerHi}${ruinHi}" data-r="${r}" data-c="${c}" data-center="${isCenter}"
      ${b?`onmouseenter="tipBldg(event,'${G.grid[r][c]}')"`:``}
      onmouseleave="hideTooltip()"
      onclick="onCell(${r},${c})"
      ondragover="onCellDragOver(event,${r},${c});onTalentDragOverCell(event,${r},${c})"
      ondragleave="onCellDragLeave(${r},${c});onTalentDragLeaveCell(${r},${c})"
      ondrop="onCellDrop(event,${r},${c});onTalentDropCell(event,${r},${c})">`;
    if(!b && isCenter){
      h+=`<div style="position:absolute;width:6px;height:6px;border-radius:50%;background:rgba(179,58,0,.15);top:50%;left:50%;transform:translate(-50%,-50%);pointer-events:none;"></div>`;
    }
    if(b){
      const totalMod=modVal;
      const baseBonus=(b.fn(1)-1)+(G.bldgUpgrades?.[`${r},${c}`]||0);
      if(b.special==='redirect'){
        h+=`<div style="font-size:32px;line-height:1;">${b.emoji}</div>`;
        if(baseBonus>0) h+=`<div style="font-size:8px;font-weight:700;color:var(--money);">+${baseBonus}</div>`;
      } else {
        h+=`<div class="cemoji">${b.emoji}</div>`;
        h+=`<div class="cname">${b.name}</div>`;
      }
      h+=`<div style="font-size:9px;font-weight:700;color:var(--money);line-height:1;">+${baseBonus}${totalMod!==0?`<span style="color:${totalMod>0?'var(--green)':'var(--red)'}">${totalMod>0?'+':''}${totalMod}</span>`:''}`;
      h+=`</div>`;
      if(totalMod!==0) h+=`<div class="${totalMod>0?'cell-mod-pos':'cell-mod-neg'}">${totalMod>0?'+':''}${totalMod}</div>`;
    }
    if(modVal!==0&&!b) h+=`<div class="${modVal>0?'cell-mod-pos':'cell-mod-neg'}">${modVal>0?'+':''}${modVal}</div>`;
    h+=`</div>`;
  }
  h+=`</div>`;

  h+=`<div class="dside">`;
  for(let ri=0;ri<_gn;ri++) h+=`<button class="dbtn side${windDir==='right'?' wind-active':windDir?' wind-blocked':''}"
    ondragover="onDirDragOver(event,this)"
    ondragleave="onDirDragLeave(this)"
    ondrop="onDirDrop(event,'right',${ri})">←</button>`;
  h+=`</div></div>`;

  // 下排
  h+=`<div class="drow"><div style="width:28px"></div>`;
  for(let ci=0;ci<_gn;ci++) h+=`<button class="dbtn${windDir==='bottom'?' wind-active':windDir?' wind-blocked':''}"
    ondragover="onDirDragOver(event,this)"
    ondragleave="onDirDragLeave(this)"
    ondrop="onDirDrop(event,'bottom',${ci})">↑</button>`;
  h+=`<div style="width:28px"></div></div>`;

  // Free rearrange confirm button
  if(G.freeRearrange){
    h+=`<div style="display:flex;gap:6px;margin-top:6px;">
      <button class="abtn" style="flex:1;background:var(--green);color:#fff;border-color:var(--green);text-align:center;" onclick="confirmRearrange()">✅ 確認排列</button>
      <button class="abtn" style="flex:0 0 70px;text-align:center;" onclick="cancelRearrange()">✕ 取消</button>
    </div>`;
  }
  area.innerHTML=h;
}

function renderHand(){
  const el=document.getElementById('hand-list');
  const items=G.hand.filter(h=>h.count>0);
  if(!items.length){el.innerHTML='<div style="font-size:10px;color:var(--hi);">手牌空了</div>';return;}
  el.innerHTML=items.map(h=>{
    const b=BLDG[h.id];
    const sel=G.sel===h.id;
    const canSel=G.phase==='place';
    return `<div class="hi${sel?' sel':''}${!canSel?' off':''}"
      draggable="${canSel?'true':'false'}"
      ondragstart="onBldgDragStart(event,'${h.id}')"
      ondragend="onBldgDragEnd(event)"
      onmouseenter="tipBldg(event,'${h.id}')" 
      onmouseleave="hideTooltip()"
      onclick="selBldg('${h.id}')">
      <div class="hi-em">${b.emoji}</div>
      <div style="flex:1"><div class="hi-nm">${b.name}</div><div class="hi-ds">${b.desc}</div></div>
      <div class="hi-ct">×${h.count}</div>
    </div>`;
  }).join('');
}



function renderSideLog(){
  const el=document.getElementById('side-log');
  if(!el) return;
  let html='';

  // 過去回合（舊→新，最新在底部）
  if(G.turnLogHistory){
    const reversed=[...G.turnLogHistory].reverse();
    reversed.forEach(t=>{
      html+=`<div class="log-turn-block" style="opacity:.7;">`;
      html+=`<div class="log-turn-hdr" style="color:var(--mu);">第${t.round}輪 回合${t.turn}</div>`;
      html+=t.entries.map(e=>{
        const isCalc=e.msg.startsWith('  ');
        return `<div class="${isCalc?'log-calc':'log-entry'} ${e.cls||''}">${e.msg.trim()}</div>`;
      }).join('');
      html+=`</div>`;
    });
  }

  // 當前回合（最新，在最底部）
  if(G.turnLog&&G.turnLog.length>0){
    html+=`<div class="log-turn-block">`;
    html+=`<div class="log-turn-hdr">第${G.round}輪 回合${G.turn}</div>`;
    html+=G.turnLog.map(e=>{
      const isCalc=e.msg.startsWith('  ');
      return `<div class="${isCalc?'log-calc':'log-entry'} ${e.cls||''}">${e.msg.trim()}</div>`;
    }).join('');
    html+=`</div>`;
  }

  if(!html) html='<div style="font-size:9px;color:var(--hi);">尚無記錄</div>';
  el.innerHTML=html;
  // 自動捲到最底顯示最新 log
  el.scrollTop=el.scrollHeight;
}

function pulse(r,c){
  const el=document.querySelector(`[data-r="${r}"][data-c="${c}"]`);
  if(!el)return;
  el.classList.remove('pulse');void el.offsetWidth;el.classList.add('pulse');
  setTimeout(()=>el.classList.remove('pulse'),450);
}
function fdelta(text,color,x,y){
  const d=document.createElement('div');
  d.className='delta';d.textContent=text;
  d.style.cssText=`left:${x}px;top:${y}px;color:${color};`;
  document.body.appendChild(d);setTimeout(()=>d.remove(),950);
}


// ══════════════════════════════════════
// 浮動提示工具
// ══════════════════════════════════════
const tip=()=>document.getElementById('tooltip');
function showTooltip(e,html){
  const t=tip(); if(!t)return;
  t.innerHTML=html; t.classList.add('show');
  positionTooltip(e);
}
function positionTooltip(e){
  const t=tip(); if(!t)return;
  let x=e.clientX+14, y=e.clientY+14;
  if(x+210>window.innerWidth) x=e.clientX-220;
  if(y+120>window.innerHeight) y=e.clientY-130;
  t.style.left=x+'px'; t.style.top=y+'px';
}
function hideTooltip(){ const t=tip(); if(t) t.classList.remove('show'); }
document.addEventListener('mousemove',e=>{ if(tip()&&tip().classList.contains('show')) positionTooltip(e); });

// ══════════════════════════════════════
// 選擇卡片渲染（設施/合夥人統一格式）
// ══════════════════════════════════════
function makeSelCard(emoji,name,desc,pos,neg,onclick,extraClass='',pid='',hoverFn=''){
  const negLine=neg&&neg!=='無'?`<div class="sel-card-neg">✕ ${neg}</div>`:'';
  const tipParts=[desc||''];
  if(pos) tipParts.push('✓ '+pos);
  if(neg&&neg!=='無') tipParts.push('✕ '+neg);
  const tipAttr=tipParts.join('\n').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
  const avatarSrc = PARTNER_AVATARS && PARTNER_AVATARS[pid];
  const emojiHtml = avatarSrc
    ? `<img src="${avatarSrc}" class="sel-card-avatar" alt="${name}">`
    : `<div class="sel-card-emoji">${emoji}</div>`;
  const hoverCall = hoverFn || `DM.onPartnerHover(this.querySelector('.sel-card-name').textContent); DM.onBldgHover(Object.keys(BLDG).find(k=>BLDG[k].name===this.querySelector('.sel-card-name').textContent)||'');`;
  return `<div class="sel-card ${extraClass}" onclick="${onclick}"
    data-tip="${tipAttr}"
    onmouseenter="tipFromAttr(event,this); ${hoverCall}"
    onmouseleave="hideTooltip()">
    ${emojiHtml}
    <div class="sel-card-name">${name}</div>
    <div class="sel-card-desc">${desc||''}</div>
    ${pos?`<div class="sel-card-pos">✓ ${pos}</div>`:''}
    ${negLine}
  </div>`;
}


// ══════════════════════════════════════
// 通用卡牌選擇器（設施/合夥人）
// ══════════════════════════════════════
let _cardChooserSkipFn=null;
function showCardChooser(title, cards, onSkip){
  _cardChooserSkipFn=onSkip;
  const el=document.getElementById('card-chooser');
  document.getElementById('card-chooser-title').textContent=title;
  document.getElementById('card-chooser-cards').innerHTML=cards.map(card=>
    makeSelCard(card.emoji,card.name,card.desc,card.pos,card.neg,card.onclick,'',card.pid||'')
  ).join('');
  document.getElementById('card-chooser-skip').onclick=()=>{
    closeCardChooser();
    if(_cardChooserSkipFn) _cardChooserSkipFn();
  };
  el.style.display='flex';
}
function closeCardChooser(){
  document.getElementById('card-chooser').style.display='none';
  _cardChooserSkipFn=null;
}
function cardChooserPick(fn){
  closeCardChooser();
  fn();
}

function tipFromAttr(e,el){
  const raw=(el.getAttribute('data-tip')||'')
    .replace(/&quot;/g,'"').replace(/&#39;/g,"'");
  const txt=raw.replace(/\|/g,'\n');
  if(txt&&e) showTooltip(e,txt);
}
function tipBldg(e,id){
  const b=BLDG[id]; if(!b)return;
  showTooltip(e, b.name + '\n' + (b.desc||'') + '\n基礎輸出: +' + (b.fn(1)-1));
  DM.onBldgHover(id);
}



// ══════════════════════════════════════
// 扇形手牌系統
// ══════════════════════════════════════
let fanEventCards = []; // 當前事件選擇卡 [{id,emoji,name,desc,pos,neg,onclick,isSkip}]


function fanCardClick(i) {
  const area = document.getElementById('hand-fan-area');
  if (!area || !area._cards) return;
  const card = area._cards[i];
  if (!card) return;

  if (card.type === 'element') {
    addLog('💡 將元素卡拖曳到地圖邊緣箭頭投入');
    return;
  } else if (card.type === 'bldg') {
    if (card.disabled) return;
    selBldg(card.id);
  } else if (card.type === 'event') {
    if (card.disabled) return;
    if (card.isSkip) {
      fanEventCards = [];
      renderFanHand();
      if (card.onSkip) card.onSkip();
      return;
    }
    const el = document.getElementById('fancard-' + i);
    if (el) {
      el.classList.add('burning');
      setTimeout(() => {
        fanEventCards = [];
        renderFanHand();
        if (card.onClickFn) card.onClickFn();
      }, 650);
    } else {
      fanEventCards = [];
      renderFanHand();
      if (card.onClickFn) card.onClickFn();
    }
  }
}

function fanCardHover(i, entering, evt) {
  const el = document.getElementById('fancard-' + i);
  if (!el) return;
  if (entering) {
    el.style.zIndex = 200;
    if (evt) tipFromAttr(evt, el);
    // trigger dialogue for building cards
    const area = document.getElementById('hand-fan-area');
    if (area && area._cards) {
      const card = area._cards[i];
      if (card) {
        if (card.type === 'bldg') DM.onBldgHover(card.id);
        else if (card.type === 'element') tryDialogue('bldg_hover_元素卡');
      }
    }
  } else {
    const area = document.getElementById('hand-fan-area');
    const zi = area && area._cards ? (i + 1) : 1;
    el.style.zIndex = String(zi);
    hideTooltip();
  }
}

function renderFanHand() {
  const area = document.getElementById('hand-fan-area');
  if (!area) return;

  const cards = [];

  // 1. Building hand cards — expand by count
  G.hand.filter(h => h.count > 0).forEach(h => {
    const b = BLDG[h.id];
    if (!b) return;
    const canSel = G.phase === 'place';
    for (let n = 0; n < h.count; n++) {
      cards.push({
        type: 'bldg', id: h.id,
        emoji: b.emoji, name: b.name, desc: b.desc,
        selected: G.sel === h.id,
        disabled: !canSel,
        draggable: canSel,
      });
    }
  });

  // 2. Event choice cards (if any)
  fanEventCards.forEach((ev, ei) => {
    cards.push({ type: 'event', _evIdx: ei, ...ev });
  });

  // 人材卡已移至左側面板 (renderTalentPanel)

  // 3. Element card always last (rightmost)
  if (G.card) {
    const emojis = {money:'💵', material:'🪨', goods:'📦', diamond:'💎'};
    const canDrag = G.phase === 'place';
    cards.push({
      type: 'element',
      emoji: emojis[G.card.type] || '💵',
      name: TLABEL[G.card.type] || '元素',
      val: G.card.value,
      draggable: canDrag,
      disabled: !canDrag,
    });
  }

  if (cards.length === 0) { area.innerHTML = ''; return; }

  const total = cards.length;
  const maxAngle = Math.min(25, total * 4);

  area.innerHTML = cards.map((card, i) => {
    const frac  = total > 1 ? (i / (total - 1)) - 0.5 : 0;
    const angle = frac * maxAngle * 2;
    const sinkY = Math.abs(frac) * 14;
    const zi    = card.selected ? 50 : i + 1;
    const tx    = 0; // flex handles horizontal spacing

    const selBorder = card.selected ? 'border-color:var(--acc) !important;' : '';
    const dimStyle  = '';
    const typeClass = card.type === 'event' ? ' event-card' :
                      card.type === 'element' ? ' el-card-fan' :
                      card.type === 'talent' ? ' talent-card' : '';

    // Back face HTML — unified pattern, no content
    const backHTML = `<div class="fc-back-mark">🏙</div>`;

    // Front face HTML
    let frontHTML = '';
    if (card.type === 'element') {
      frontHTML = `<div class="fc-emoji">${card.emoji}</div>
        <div class="fc-val">${card.val}</div>
        <div class="fc-type">${card.name}</div>
        <div class="fc-desc" style="color:var(--mu);font-size:7px;">拖曳投入</div>`;
    } else if (card.type === 'talent') {
      frontHTML = `<div class="fc-emoji">${card.emoji}</div>
        <div class="fc-name">${card.name}</div>
        <div class="fc-desc">${card.desc}</div>`;
    } else if (card.type === 'bldg') {
      frontHTML = `<div class="fc-emoji">${card.emoji}</div>
        <div class="fc-name">${card.name}</div>
        <div class="fc-desc">${card.desc}</div>`;
    } else {
      frontHTML = `<div class="fc-emoji">${card.emoji || '🎴'}</div>
        <div class="fc-name">${card.name}</div>
        <div class="fc-desc">${card.desc || ''}</div>
        ${card.pos ? `<div style="font-size:7px;color:var(--green);">✓${card.pos}</div>` : ''}`;
    }

    const tipData = [card.name, card.desc||'', card.pos?'✓'+card.pos:'', card.neg&&card.neg!=='無'?'✕'+card.neg:'']
      .filter(Boolean).join('|').replace(/"/g,'&quot;');

    // drag attrs for element card
    const cardIdx = i; // capture for talent drag
    const dragAttrs = card.draggable && card.type === 'element'
      ? `draggable="true" ondragstart="onCardDragStart(event)" ondragend="onCardDragEnd(event)"
         ondragover="onTalentDragOver(event)" ondragleave="onTalentDragLeave(event)" ondrop="onTalentDrop(event)"`
      : card.draggable && card.type === 'bldg'
      ? `draggable="true" ondragstart="onBldgDragStart(event,'${card.id}')" ondragend="onBldgDragEnd(event)"`
      : card.draggable && card.type === 'talent'
      ? `draggable="true" ondragstart="onTalentDragStart(event,${i})" ondragend="onTalentDragEnd(event)"`
      : '';

    return `<div class="fan-card${typeClass}" id="fancard-${i}"
      style="transform: translateY(${sinkY}px) rotate(${angle}deg); z-index:${zi}; ${selBorder}${dimStyle}background:var(--sur);border:1.5px solid var(--br2);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;padding:6px 5px;box-shadow:0 4px 12px rgba(42,26,8,.13);"
      onclick="fanCardClick(${i})"
      onmouseenter="fanCardHover(${i},true,event)"
      onmouseleave="fanCardHover(${i},false,null)"
      data-tip="${tipData}"
      ${dragAttrs}
      ${card.type==='element'?'ondragover="onTalentDragOver(event)" ondrop="onTalentDrop(event)" ondragleave="onTalentDragLeave(event)"':''}
      >${frontHTML}</div>`;
  }).join('');

  area._cards = cards;
}

// Show event cards in fan (replaces action chooser / card chooser for events)


// showCardChooser uses central overlay (no fan override)


// 從合夥人卡片飛出 +X 收益動畫
function profitFlyFromPartner(pid, amount) {
  const row = document.getElementById('partner-row');
  if (!row) return;
  // find the joker card
  const cards = row.querySelectorAll('.joker-card');
  let srcEl = null;
  G.partners.forEach((p, i) => { if(p===pid) srcEl=cards[i]; });
  const targetEl = document.getElementById('r-profit');
  if (!srcEl || !targetEl) return;

  const src = srcEl.getBoundingClientRect();
  const dst = targetEl.getBoundingClientRect();

  const fly = document.createElement('div');
  fly.className = 'profit-fly';
  fly.textContent = '+' + amount;
  fly.style.left = (src.left + src.width/2) + 'px';
  fly.style.top  = (src.top + src.height/2) + 'px';
  const dx = dst.left - src.left - src.width/2;
  fly.style.setProperty('--tx', dx + 'px');

  // pulse the joker card
  srcEl.style.transform = 'translateY(-18px) scale(1.15)';
  setTimeout(()=>{ srcEl.style.transform=''; }, 400);

  document.body.appendChild(fly);
  setTimeout(()=>fly.remove(), 1300);
}


function demolitionChargeFly(){
  const row=document.getElementById('partner-row');
  if(!row) return;
  const cards=row.querySelectorAll('.joker-card');
  let dCard=null;
  G.partners.forEach((pid,i)=>{ if(pid==='demolition') dCard=cards[i]; });
  if(!dCard) return;

  const dst=dCard.getBoundingClientRect();
  const fly=document.createElement('div');
  fly.className='profit-fly';
  fly.textContent='+1';
  fly.style.cssText=`left:${window.innerWidth/2}px;top:${window.innerHeight/2}px;color:var(--money);font-size:18px;`;
  fly.style.setProperty('--tx',(dst.left-window.innerWidth/2+dst.width/2)+'px');
  // custom animation: fly toward card (downward if card is above center)
  fly.style.animation='none';
  document.body.appendChild(fly);

  const startY=window.innerHeight/2;
  const endY=dst.top+dst.height/2;
  const startX=window.innerWidth/2;
  const endX=dst.left+dst.width/2;

  fly.animate([
    {opacity:1,transform:`translate(0,0) scale(1)`},
    {opacity:1,transform:`translate(${endX-startX}px,${endY-startY}px) scale(0.7)`},
    {opacity:0,transform:`translate(${endX-startX}px,${endY-startY}px) scale(0.3)`}
  ],{duration:600,easing:'cubic-bezier(.4,0,.2,1)'}).onfinish=()=>{
    fly.remove();
    // pulse demolition card
    if(dCard){ dCard.style.transform='translateY(-14px) scale(1.18)'; setTimeout(()=>dCard.style.transform='',350); }
    renderPartners();
  };
}


function useDemolition(){
  if(TUT.active && TUT.waitingFor==='use_demolition'){
    TUT.waitingFor = 'confirm_rearrange'; // 等待玩家點擊確認排列
  }
  if(!hasPartner('demolition')) return;
  if((G.demolitionCharges||0)<=0){ addLog('🔨 拆遷隊次數不足','b'); return; }
  if(G.phase!=='place'){ addLog('🔨 只能在放置階段使用','b'); return; }
  G.freeRearrange=true; G.moveMode=false; G.moveSrc=null;
  G._demolitionRearrange = true; // 標記為拆遷隊啟動的重排
  addLog('🔨 拆遷隊啟動！隨意移動設施，點「確認排列」完成');
  render();
}


function expandGrid(grid, newSize){
  const newGrid=Array(newSize).fill(null).map(()=>Array(newSize).fill(null));
  for(let r=0;r<Math.min(grid.length,newSize);r++)
    for(let cc=0;cc<Math.min(grid[r].length,newSize);cc++)
      newGrid[r][cc]=grid[r][cc];
  return newGrid;
}


function getWindDir(){
  const dirs=['left','right','top','bottom'];
  const labels={left:'←左',right:'→右',top:'↑上',bottom:'↓下'};
  if(!hasPartner('wind_master')) return null;
  if(!G.windDir){
    G.windDir=dirs[Math.floor(Math.random()*4)];
    addLog(`🌀 場風大師：本回合只能從 ${labels[G.windDir]} 投入`,'w');
  }
  return G.windDir;
}


// ══ 人材拖曳系統 ══
let talentDragging = false;
let talentDragIdx = -1;

function onTalentDragStart(e, idx) {
  if(G.phase !== 'place') { e.preventDefault(); return; }
  talentDragging = true;
  talentDragIdx = idx;
  e.dataTransfer.effectAllowed = 'move';
  e.dataTransfer.setData('text/plain','talent');
  setTimeout(()=>{
    const el = document.getElementById('fancard-'+idx);
    if(el) el.style.opacity = '0.45';
  },0);
}
function onTalentDragEnd(e) {
  talentDragging = false;
  talentDragIdx = -1;
  // restore all talent card opacity
  document.querySelectorAll('.talent-card').forEach(el=>el.style.opacity='');
}
function onTalentDragOver(e) {
  if(!talentDragging) return;
  e.preventDefault();
  e.dataTransfer.dropEffect = 'move';
  // highlight element card
  e.currentTarget.style.outline = '3px solid var(--green)';
  e.currentTarget.style.boxShadow = '0 0 12px rgba(42,122,58,.4)';
}
function onTalentDragLeave(e) {
  e.currentTarget.style.outline = '';
  e.currentTarget.style.boxShadow = '';
}
function onTalentDrop(e) {
  e.preventDefault();
  e.currentTarget.style.outline = '';
  e.currentTarget.style.boxShadow = '';
  if(!talentDragging) return;
  talentDragging = false;
  // Use talent: grant extra use on element card
  if((G.talentCards||0) > 0) {
    G.talentCards--;
    G.elementExtraUses = (G.elementExtraUses||0) + 1;
    addLog(`🧑‍💼 人材使用！元素獲得額外投入 ${G.elementExtraUses} 次`,'g');
    renderFanHand();
    // flash element card
    const area = document.getElementById('hand-fan-area');
    if(area && area._cards) {
      const elIdx = area._cards.findIndex(c=>c.type==='element');
      if(elIdx >= 0) {
        const elCard = document.getElementById('fancard-'+elIdx);
        if(elCard) {
          elCard.style.transform = 'translateY(-50px) scale(1.15)';
          elCard.style.boxShadow = '0 0 20px rgba(42,122,58,.6)';
          setTimeout(()=>{ elCard.style.transform=''; elCard.style.boxShadow=''; }, 500);
        }
      }
    }
  }
}

// 人材拖到設施格子上：本回合暫時 +1
function onTalentDropCell(e, r, c) {
  e.preventDefault();
  const cellEl = document.querySelector(`[data-r="${r}"][data-c="${c}"]`);
  if(cellEl){ cellEl.style.outline=''; cellEl.style.boxShadow=''; }
  if(!talentDragging) return;
  if(!G.grid[r][c]){ addLog('🧑‍💼 沒有設施可以強化','b'); return; }
  if((G.talentCards||0) <= 0) return;
  talentDragging = false;
  G.talentCards--;
  // Store as cellMod (temporary, cleared each turn)
  const key = `${r},${c}`;
  G.cellMods[key] = (G.cellMods[key]||0) + 1;
  const b = BLDG[G.grid[r][c]];
  addLog(`🧑‍💼 人材強化 ${b.emoji}${b.name}！本回合 +1`,'g');
  // Visual flash on cell
  if(cellEl){
    cellEl.style.outline = '3px solid var(--money)';
    cellEl.style.boxShadow = '0 0 14px rgba(176,96,0,.5)';
    setTimeout(()=>{ cellEl.style.outline=''; cellEl.style.boxShadow=''; },800);
  }
  renderFanHand();
  render();
}

function onTalentDragOverCell(e, r, c) {
  if(!talentDragging) return;
  if(!G.grid[r][c]) return;
  e.preventDefault();
  const cellEl = document.querySelector(`[data-r="${r}"][data-c="${c}"]`);
  if(cellEl){ cellEl.style.outline='3px solid var(--money)'; cellEl.style.boxShadow='0 0 12px rgba(176,96,0,.4)'; }
}

function onTalentDragLeaveCell(r, c) {
  const cellEl = document.querySelector(`[data-r="${r}"][data-c="${c}"]`);
  if(cellEl){ cellEl.style.outline=''; cellEl.style.boxShadow=''; }
}


// ══════════════════════════════════════
// 中央區域判斷
// ══════════════════════════════════════
function isCenterCell(r, cc){
  const n = GN();
  // Center = inner (n-2)×(n-2) block
  // 4×4 → rows 1-2, cols 1-2 (0-indexed)
  // 5×5 → rows 1-3, cols 1-3
  const margin = 1;
  return r >= margin && r < n - margin && cc >= margin && cc < n - margin;
}

function getCenterCells(){
  const n = GN();
  const cells = [];
  for(let r=0;r<n;r++) for(let cc=0;cc<n;cc++)
    if(isCenterCell(r,cc)) cells.push([r,cc]);
  return cells;
}


// 中央區域定義
// 4×4: (1,1)(1,2)(2,1)(2,2) — 內圈2×2
// 5×5: (1,1)~(3,3) — 內圈3×3
function getCenterCells(n){
  n = n || GN();
  const cells = new Set();
  if(n===4){
    [[1,1],[1,2],[2,1],[2,2]].forEach(([r,c])=>cells.add(`${r},${c}`));
  } else if(n===5){
    for(let r=1;r<=3;r++) for(let cc=1;cc<=3;cc++) cells.add(`${r},${cc}`);
  } else {
    // generic: exclude outer ring
    for(let r=1;r<n-1;r++) for(let cc=1;cc<n-1;cc++) cells.add(`${r},${cc}`);
  }
  return cells;
}
function isCenterCell(r,c){ return getCenterCells().has(`${r},${c}`); }


function destroyFacility(r, c){
  const bId=G.grid[r][c];
  if(!bId) return;
  G.grid[r][c]=null;
  // 設施破壞者：+500收益
  if(hasPartner('facility_destroyer')){
    G.profit+=500;
    addLog(`💣 設施破壞者：${BLDG[bId].name}被消滅，+500收益！`,'g');
    setTimeout(()=>profitFlyFromPartner('facility_destroyer',500),100);
  }
  // Clear upgrades for that cell
  if(G.bldgUpgrades) delete G.bldgUpgrades[`${r},${c}`];
  if(!G.ruinCells) G.ruinCells=new Set();
  G.ruinCells.add(`${r},${c}`);
  // 廢墟掠奪者：留下廢墟標記
  if(hasPartner('ruin_scavenger')) addLog(`💀 廢墟掠奪者：(${r+1},${c+1})成為廢墟，資源通過+5`,'g');
  renderFanHand();
  render();
}


// 套用格子升級加成（所有special設施共用）
function applyUpgradeBonus(r, c, val, bName){
  const key=`${r},${c}`;
  const upg=G.bldgUpgrades&&G.bldgUpgrades[key]||0;
  if(upg>0){
    addLog(`    ⬆ ${bName}升級加成：+${upg}`,'g');
    return val+upg;
  }
  return val;
}


function renderTalentPanel(){
  const panel=document.getElementById('talent-panel');
  const title=document.getElementById('talent-section-title');
  if(!panel) return;
  const n=G.talentCards||0;
  if(title) title.style.display='block';
  panel.style.display='flex';
  if(n===0){
    panel.innerHTML='<div style="font-size:9px;color:var(--hi);padding:4px 0;">尚無人材</div>';
    return;
  }
  // Show talent tokens as small cards
  panel.innerHTML=Array(n).fill(0).map((_,i)=>`
    <div class="talent-token" title="人材：拖到元素卡多投入一次，或拖到設施格+1"
      draggable="true"
      ondragstart="onTalentDragStart(event,${i})"
      ondragend="onTalentDragEnd(event)"
      style="width:38px;height:50px;background:linear-gradient(145deg,#fff9ee,#fff3d4);
        border:1.5px solid var(--money);border-radius:7px;
        display:flex;flex-direction:column;align-items:center;justify-content:center;
        gap:2px;cursor:grab;font-size:18px;box-shadow:0 2px 6px rgba(42,26,8,.12);">
      <div>🧑‍💼</div>
      <div style="font-size:7px;font-weight:700;color:var(--money);">人材</div>
    </div>
  `).join('');
}


function pickStarterPartner(pid){
  G.partners.push(pid);
  if(PARTNERS[pid]&&PARTNERS[pid].onRecruit) PARTNERS[pid].onRecruit(G);
  if(pid==='envy') addHand('envy_factory');
  addLog(`🤝 選擇了 ${PARTNERS[pid].emoji}${PARTNERS[pid].name} 作為起始合夥人！`,'g');
  // 未選到的兩位加入合夥人招募池
  const starters=['demolition','tanya','leya'];
  starters.filter(s=>s!==pid).forEach(s=>{
    if(!G.partnerPool) G.partnerPool=[];
    if(!G.partnerPool.includes(s)) G.partnerPool.unshift(s); // 加到最前面提高機率
    addLog(`🤝 ${PARTNERS[s].emoji}${PARTNERS[s].name} 進入合夥人招募池`,'w');
  });
  document.getElementById('card-chooser').style.display='none';
  startRound();
}

function showStarterPartnerSelection(){
  const starters=['demolition','tanya','leya'];
  // Show card chooser with these 3 partners
  const cards=starters.map(pid=>{
    const p=PARTNERS[pid];
    return {
      emoji:p.emoji, name:p.name,
      desc:p.pos,
      pos:p.pos, neg:p.neg!=='無'?p.neg:'',
      onclick:`recruitPartner('${pid}')`
    };
  });
  // Use a custom overlay (not showCardChooser which calls startTurn after)
  const el=document.getElementById('card-chooser');
  document.getElementById('card-chooser-title').textContent='🎮 選擇你的起始合夥人';
  document.getElementById('card-chooser-cards').innerHTML=cards.map(card=>{
    const pid=card.onclick.match(/recruitPartner\('(\w+)'\)/)[1];
    return makeSelCard(card.emoji,card.name,card.desc,card.pos,card.neg,
      `pickStarterPartner('${pid}')`, '', pid,
      `DM.onStarterHover('${card.name}')`);
  }).join('');
  // Hide skip button (must choose)
  const skipBtn=document.getElementById('card-chooser-skip');
  if(skipBtn) skipBtn.style.display='none';
  el.style.display='flex';
}



function charClick(){
  // 教學期間：點擊立繪跳到下一句台詞
  if(TUT.active && TUT._speechQueue && TUT._speechIdx < TUT._speechQueue.length){
    if(TUT._speechTimer) clearTimeout(TUT._speechTimer);
    TUT._nextLine();
    return;
  }
  const lines=[
    '👩‍💼 譚雅：設施不夠用的話，手牌空間小於16我就會幫你補！',
    '👩‍🔧 蕾雅：把手牌的設施直接拖到同類設施上，就能幫你升級！',
    '👩‍💼 譚雅：物流中心能讓資源多繞幾格，增加通過的設施數量喔！',
    '👩‍🔧 蕾雅：人材可以拖到格子上讓設施本回合+1，或拖到元素卡多投入一次！',
  ];
  DM.show(lines[Math.floor(Math.random()*lines.length)], 5000);
}
